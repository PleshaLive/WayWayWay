<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Admin Panel - Manage Teams & Players</title>
  <!-- Подключаем jQuery -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <!-- Подключаем шрифт Blender Pro -->
  <link href="https://fonts.googleapis.com/css2?family=Blender+Pro:wght@500&display=swap" rel="stylesheet">
  <style>
    /* Общие стили и анимированный градиентный фон */
    body {
      margin: 0;
      padding: 0;
      background: linear-gradient(-45deg, #1E1E1E, #2C243B, #1E1E1E, #2C243B);
      background-size: 600% 600%;
      animation: gradientBG 20s ease infinite;
      font-family: 'Blender Pro', Arial, sans-serif;
      color: #e0e0e0;
    }
    @keyframes gradientBG {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .container {
      max-width: 1440px;
      margin: 20px auto;
      padding: 20px;
    }
    h1 {
      text-align: center;
      margin-bottom: 30px;
      color: #ffffff;
    }
    
    /* Сетка карточек команд */
    .teams-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }
    .team-card {
      background: #2C243B;
      border: 2px solid #503BA9;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.6);
      width: 300px;
      padding: 20px;
      transition: transform 0.5s ease, box-shadow 0.5s ease;
    }
    .team-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.7);
    }
    .team-card h2 {
      font-size: 1.5rem;
      margin: 0 0 15px;
      text-align: center;
      color: #ffffff;
    }
    .team-logo {
      display: block;
      margin: 0 auto 15px;
      max-height: 100px;
    }
    .team-actions {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-bottom: 15px;
    }
    .team-actions button {
      padding: 5px 10px;
      border: none;
      border-radius: 4px;
      background-color: #007acc;
      color: #fff;
      cursor: pointer;
      font-size: 0.85em;
      transition: background-color 0.3s ease;
    }
    .team-actions button:hover {
      background-color: #005fa3;
    }
    
    /* Стили для списка игроков внутри команды */
    .players-list {
      margin-top: 10px;
    }
    .players-list table {
      width: 100%;
      border-collapse: collapse;
      background-color: #1e1e1e;
    }
    .players-list th, .players-list td {
      border: 1px solid #333;
      padding: 8px;
      text-align: left;
      vertical-align: middle;
      font-size: 0.9rem;
      color: #e0e0e0;
    }
    .players-list th {
      background-color: #2e2e2e;
      text-transform: uppercase;
    }
    .players-list img {
      max-height: 40px;
      vertical-align: middle;
    }
    
    /* Кнопки small-btn для игроков */
    .small-btn {
      padding: 5px 10px;
      margin-right: 5px;
      border: none;
      border-radius: 4px;
      background-color: #007acc;
      color: #fff;
      cursor: pointer;
      font-size: 0.85em;
      transition: background-color 0.3s ease;
    }
    .small-btn:hover {
      background-color: #005fa3;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Admin Panel</h1>
    
    <!-- Карточки команд, выводимые в сетке -->
    <div class="teams-grid">
      <% teams.forEach(function(team) { 
           var teamPlayers = players.filter(function(player) { 
             return player.teamId == team.id;
           });
      %>
        <div class="team-card" data-id="<%= team.id %>">
          <h2><%= team.name %></h2>
          <% if(team.logo){ %>
            <img src="<%= team.logo %>" alt="<%= team.name %> Logo" class="team-logo">
          <% } else { %>
            <p style="text-align:center; color:#aaa;">No Logo</p>
          <% } %>
          <div class="team-actions">
            <button class="editTeam small-btn">Edit</button>
            <button class="deleteTeam small-btn">Delete</button>
          </div>
          <div class="players-list">
            <% if(teamPlayers.length > 0){ %>
              <table>
                <thead>
                  <tr>
                    <th>Weapon Type</th>
                    <th>Name</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% teamPlayers.forEach(function(player){ %>
                    <tr data-id="<%= player.id %>">
                      <td><%= player.weapontype ? player.weapontype : '-' %></td>
                      <td><%= player.name %></td>
                      <td>
                        <button class="editPlayer small-btn">Edit</button>
                        <button class="deletePlayer small-btn">Delete</button>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %>
              <p style="text-align:center; color:#aaa;">No players</p>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  
  <script>
    $(document).ready(function(){
      // Обработчик редактирования команды
      $(document).on("click", ".editTeam", function(){
        var teamId = $(this).closest(".team-card").data("id");
        alert("Edit team with ID: " + teamId);
        // Здесь можно добавить AJAX-запрос или открыть модальное окно для редактирования
      });
      
      // Обработчик удаления команды
      $(document).on("click", ".deleteTeam", function(){
        var teamId = $(this).closest(".team-card").data("id");
        if(confirm("Delete team " + teamId + "?")){
          // AJAX DELETE-запрос сюда
          alert("Team " + teamId + " deleted (simulate)");
        }
      });
      
      // Обработчик редактирования игрока
      $(document).on("click", ".editPlayer", function(){
        var playerId = $(this).closest("tr").data("id");
        alert("Edit player with ID: " + playerId);
        // Здесь можно добавить AJAX-запрос или модальное окно для редактирования игрока
      });
      
      // Обработчик удаления игрока
      $(document).on("click", ".deletePlayer", function(){
        var playerId = $(this).closest("tr").data("id");
        if(confirm("Delete player " + playerId + "?")){
          // AJAX DELETE-запрос сюда
          alert("Player " + playerId + " deleted (simulate)");
        }
      });
    });
  </script>
</body>
</html>
