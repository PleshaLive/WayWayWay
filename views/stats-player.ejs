<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Player Profile — Galaxy Stats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
  <style>
  :root {
    --bg:      #0E0A1C; --surface: #161228; --surface2: #1e1836;
    --border:  rgba(99,102,241,0.14); --border2: rgba(255,255,255,0.06);
    --text:    #e0e7ff; --text2: #a0aec0; --muted: #5a667a;
    --primary: #6366f1; --primary2: #4f46e5;
    --success: #22c55e; --danger: #ef4444; --gold: #fbbf24;
    --r: 8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; }
  body {
    background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif;
    min-height: 100vh; -webkit-font-smoothing: antialiased;
    background-image:
      radial-gradient(ellipse at 10% 0%, rgba(79,70,229,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 90% 100%, rgba(122,100,185,0.04) 0%, transparent 50%);
  }
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(14,10,28,0.9); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0.65rem 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .header-left { display: flex; align-items: center; gap: 0.7rem; }
  .header-nav  { display: flex; gap: 0.4rem; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.38rem 0.9rem; font-size: 0.76rem; font-weight: 600;
    border-radius: 7px; border: 1px solid transparent;
    cursor: pointer; text-decoration: none; transition: all 0.15s; white-space: nowrap;
  }
  .btn-ghost   { background: transparent; border-color: rgba(99,102,241,0.3); color: #9b8fd0; }
  .btn-ghost:hover { background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.55); color: var(--primary); }
  .container { max-width: 1200px; margin: 0 auto; padding: 1.4rem; }

  /* Hero */
  .hero {
    position: relative; overflow: hidden;
    background: rgba(22,18,40,0.85); border: 1px solid var(--border);
    border-radius: 16px; margin-bottom: 1rem;
  }
  .hero-inner {
    display: flex; align-items: flex-end; gap: 2rem; flex-wrap: wrap;
    padding: 1.8rem 2rem 1.6rem;
    position: relative; z-index: 1;
  }
  .hero-avatar-wrap { position: relative; flex-shrink: 0; }
  .hero-avatar {
    width: 140px; height: 140px; border-radius: 16px;
    object-fit: cover;
    border: 3px solid rgba(99,102,241,0.4);
    background: rgba(0,0,0,0.4);
    display: block;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(99,102,241,0.1);
  }
  .hero-avatar-ph {
    width: 140px; height: 140px; border-radius: 16px; flex-shrink: 0;
    background: rgba(79,70,229,0.15); border: 3px solid rgba(99,102,241,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem; color: var(--muted);
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  }
  .hero-bg-blur {
    position: absolute; inset: 0; z-index: 0;
    filter: blur(60px) saturate(1.4); opacity: 0.18;
    background-size: cover; background-position: center;
  }
  .hero-info { flex: 1; min-width: 0; padding-bottom: 0.3rem; }
  .hero-name  { font-size: 2rem; font-weight: 900; line-height: 1.1; letter-spacing: -0.01em; }
  .hero-team  { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.4rem; color: var(--text2); font-size: 0.85rem; }
  .hero-team-logo { width: 18px; height: 18px; object-fit: contain; }
  .hero-steam { font-size: 0.63rem; color: var(--muted); margin-top: 0.25rem; font-family: monospace; }
  .rating-big { text-align: center; flex-shrink: 0; padding-bottom: 0.3rem; }
  .rating-big-val { font-size: 3rem; font-weight: 900; line-height: 1; }
  .rating-big-label { font-size: 0.62rem; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 0.25rem; }

  /* Stat grid */
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px,1fr)); gap: 0.6rem; margin-bottom: 1rem; }
  .stat-box {
    background: rgba(22,18,40,0.7); border: 1px solid var(--border);
    border-radius: var(--r); padding: 0.75rem 0.9rem; text-align: center;
  }
  .stat-box-val   { font-size: 1.4rem; font-weight: 800; }
  .stat-box-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.15rem; }

  /* Multi-kill row */
  .mk-row { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .mk-box {
    flex: 1; min-width: 90px; background: rgba(22,18,40,0.7); border: 1px solid var(--border);
    border-radius: var(--r); padding: 0.6rem 0.8rem; display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
  }
  .mk-val   { font-size: 1.3rem; font-weight: 800; }
  .mk-label { font-size: 0.62rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

  /* Card */
  .card { background: rgba(22,18,40,0.7); border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 1rem; }
  .card-header {
    padding: 0.75rem 1rem; border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; gap: 0.5rem;
  }
  .card-title { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--primary); }

  /* Table */
  .stats-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
  .stats-table th {
    padding: 0.45rem 0.7rem; text-align: left; font-size: 0.63rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--border2); white-space: nowrap;
  }
  .stats-table td { padding: 0.45rem 0.7rem; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; }
  .stats-table tr:last-child td { border-bottom: none; }
  .stats-table tr:hover td { background: rgba(99,102,241,0.05); }
  .stats-table th.r, .stats-table td.r { text-align: right; }

  /* History item */
  .hist-item {
    display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap;
    padding: 0.55rem 0.9rem; border-bottom: 1px solid rgba(255,255,255,0.03);
    cursor: pointer; transition: background 0.15s;
  }
  .hist-item:hover { background: rgba(99,102,241,0.05); }
  .hist-item:last-child { border-bottom: none; }
  .map-badge {
    background: rgba(99,102,241,0.1); border: 1px solid var(--border);
    border-radius: 5px; padding: 0.1rem 0.45rem; font-size: 0.66rem; font-weight: 700;
    color: var(--primary); letter-spacing: 0.05em; flex-shrink: 0;
  }
  .hist-vs { flex: 1; font-size: 0.8rem; font-weight: 600; min-width: 0;
             display: flex; align-items: center; gap: 0.4rem; }
  .hist-score { font-weight: 800; font-size: 0.88rem; }
  .ct-col { color: #38bdf8; }
  .t-col  { color: #fbbf24; }
  .hist-kda { font-size: 0.76rem; font-weight: 700; white-space: nowrap; }
  .hist-rating { font-size: 0.76rem; font-weight: 700; }
  .win-tag  { font-size: 0.62rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 4px; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
  .loss-tag { font-size: 0.62rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 4px; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.2); color: #f87171; }
  .hist-date { font-size: 0.65rem; color: var(--muted); white-space: nowrap; }

  .no-data { text-align: center; padding: 2.5rem; color: var(--muted); font-style: italic; font-size: 0.85rem; }
  .val-good { color: #4ade80; }
  .val-bad  { color: #f87171; }
  .val-gold { color: var(--gold); }

  /* rating bar */
  .rb { display: flex; align-items: center; gap: 0.45rem; min-width: 80px; }
  .rb-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
  .rb-fill { height: 100%; border-radius: 2px; }
  .rb-val  { font-size: 0.78rem; font-weight: 700; min-width: 34px; text-align: right; }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.3); border-radius: 3px; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-left">
    <a href="javascript:history.back()" class="btn btn-ghost"><i class="fas fa-arrow-left"></i></a>
    <span style="font-size:0.9rem;font-weight:700;color:var(--primary)" id="pg-title">Player Profile</span>
  </div>
  <nav class="header-nav">
    <a href="/stats" class="btn btn-ghost"><i class="fas fa-chart-bar"></i> Stats</a>
    <a href="/admin" class="btn btn-ghost"><i class="fas fa-shield-alt"></i> Admin</a>
  </nav>
</header>

<div class="container" id="main">
  <div class="no-data"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;display:block;margin-bottom:0.5rem"></i>Loading...</div>
</div>

<script>
const steamId = new URLSearchParams(location.search).get('id');
if (!steamId) {
  document.getElementById('main').innerHTML = '<div class="no-data">No player ID specified in URL (?id=STEAMID)</div>';
} else {
  fetch('/api/stats/player/' + encodeURIComponent(steamId))
    .then(r => r.ok ? r.json() : Promise.reject(r.status))
    .then(render)
    .catch(e => document.getElementById('main').innerHTML = `<div class="no-data">Player not found or no stats yet.<br><small style="color:var(--muted)">${steamId}</small></div>`);
}

function ratingColor(r) {
  if (r >= 1.15) return '#4ade80';
  if (r >= 1.0)  return '#a3e635';
  if (r >= 0.85) return '#fbbf24';
  return '#f87171';
}
function ratingBar(val, max) {
  const pct = Math.min(100, (val / (max || 2)) * 100);
  const c = ratingColor(val);
  return `<div class="rb"><div class="rb-bar"><div class="rb-fill" style="width:${pct}%;background:${c}"></div></div><div class="rb-val" style="color:${c}">${val.toFixed(2)}</div></div>`;
}
function ago(iso) {
  if (!iso) return '';
  const diff = Date.now() - new Date(iso).getTime();
  if (diff < 60000) return 'just now';
  if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
  return new Date(iso).toLocaleDateString();
}
function fmt(n) { return n !== undefined && n !== null ? n : '—'; }

function render(p) {
  document.title = (p.name || p.steamId) + ' — Galaxy Stats';
  document.getElementById('pg-title').textContent = p.name || p.steamId;

  const ratingColor_ = ratingColor(p.galaxyRating);
  const avatarHtml = p.photo
    ? `<div class="hero-avatar-wrap">
         <img class="hero-avatar" src="${p.photo}" alt="${p.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
         <div class="hero-avatar-ph" style="display:none"><i class="fas fa-user"></i></div>
       </div>`
    : `<div class="hero-avatar-ph"><i class="fas fa-user"></i></div>`;
  const bgStyle = p.photo ? `style="background-image:url('${p.photo}')"` : '';

  const html = `
    <!-- Hero -->
    <div class="hero">
      <div class="hero-bg-blur" ${bgStyle}></div>
      <div class="hero-inner">
        ${avatarHtml}
        <div class="hero-info">
          <div class="hero-name">${p.name || p.steamId}</div>
          <div class="hero-team">
            <i class="fas fa-users" style="font-size:0.7rem"></i>
            ${p.teamId ? `<span>${p.teamId}</span>` : '<span style="color:var(--muted)">No team</span>'}
          </div>
          <div class="hero-steam">${p.steamId}</div>
        </div>
        <div class="rating-big">
          <div class="rating-big-val" style="color:${ratingColor_}">${p.galaxyRating.toFixed(2)}</div>
          <div class="rating-big-label">Galaxy Rating</div>
        </div>
      </div>
    </div>

    <!-- Key stats -->
    <div class="stat-grid">
      <div class="stat-box"><div class="stat-box-val">${p.matchesPlayed}</div><div class="stat-box-label">Matches</div></div>
      <div class="stat-box"><div class="stat-box-val ${p.kd >= 1 ? 'val-good' : 'val-bad'}">${p.kd}</div><div class="stat-box-label">K/D</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.adr}</div><div class="stat-box-label">ADR</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.kast}%</div><div class="stat-box-label">KAST%</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.hsRate}%</div><div class="stat-box-label">HS%</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.kills}</div><div class="stat-box-label">Kills</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.deaths}</div><div class="stat-box-label">Deaths</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.assists}</div><div class="stat-box-label">Assists</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.kpr}</div><div class="stat-box-label">KPR</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.dpr}</div><div class="stat-box-label">DPR</div></div>
      <div class="stat-box"><div class="stat-box-val val-gold">${p.mvps}</div><div class="stat-box-label">MVPs</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.firstKills}</div><div class="stat-box-label">Entry Kills</div></div>
      <div class="stat-box"><div class="stat-box-val">${p.firstDeaths}</div><div class="stat-box-label">First Deaths</div></div>
      <div class="stat-box"><div class="stat-box-val" style="color:#fbbf24">${p.bombPlants}</div><div class="stat-box-label">Bomb Plants</div></div>
      <div class="stat-box"><div class="stat-box-val" style="color:#38bdf8">${p.bombDefuses}</div><div class="stat-box-label">Defuses</div></div>
    </div>

    <!-- Multi-kills -->
    <div class="mk-row">
      <div class="mk-box"><div class="mk-val" style="color:#60a5fa">${p.threeKills}</div><div class="mk-label">3K Rounds</div></div>
      <div class="mk-box"><div class="mk-val" style="color:#a78bfa">${p.fourKills}</div><div class="mk-label">4K Rounds</div></div>
      <div class="mk-box"><div class="mk-val val-good">${p.fiveKills}</div><div class="mk-label">Aces (5K)</div></div>
      <div class="mk-box"><div class="mk-val">${p.rounds}</div><div class="mk-label">Total Rounds</div></div>
      <div class="mk-box"><div class="mk-val">${p.headshots}</div><div class="mk-label">HS Total</div></div>
    </div>

    <!-- Per-map stats -->
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fas fa-map"></i> Stats by Map</div></div>
      ${p.mapStats.length ? `
        <table class="stats-table">
          <thead><tr>
            <th>Map</th>
            <th class="r">M</th><th class="r">W</th><th class="r">L</th><th class="r">Win%</th>
            <th class="r">K/D</th><th class="r">ADR</th><th class="r">KAST%</th>
            <th class="r">HS%</th><th class="r">MVP</th>
            <th class="r">3K</th><th class="r">4K</th><th class="r">5K</th>
            <th class="r" style="min-width:100px">Rating</th>
          </tr></thead>
          <tbody>${p.mapStats.map(m => `<tr>
            <td><span style="font-weight:700;color:var(--primary)">${m.displayName}</span></td>
            <td class="r">${m.matches}</td>
            <td class="r val-good">${m.wins}</td>
            <td class="r val-bad">${m.matches - m.wins}</td>
            <td class="r ${m.winRate >= 50 ? 'val-good' : 'val-bad'}">${m.winRate}%</td>
            <td class="r ${m.kd >= 1 ? 'val-good' : 'val-bad'}">${m.kd}</td>
            <td class="r">${m.adr}</td>
            <td class="r">${m.kast}%</td>
            <td class="r">${m.hsRate}%</td>
            <td class="r val-gold">${m.mvps}</td>
            <td class="r" style="color:#60a5fa">${m.threeKills}</td>
            <td class="r" style="color:#a78bfa">${m.fourKills}</td>
            <td class="r val-good">${m.fiveKills}</td>
            <td class="r">${ratingBar(m.galaxyRating, 2)}</td>
          </tr>`).join('')}</tbody>
        </table>` : '<div class="no-data">No map data yet</div>'}
    </div>

    <!-- Recent matches -->
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="fas fa-history"></i> Recent Matches</div></div>
      ${p.recentMatches.length ? p.recentMatches.map(m => {
        const ps = m.playerStats;
        const playerWon = ps && m.winner && ps._team && (ps._team === 'CT' ? m.teamCT?.name : m.teamT?.name) === m.winner;
        const resultTag = !m.winner ? '' : playerWon ? '<span class="win-tag">WIN</span>' : '<span class="loss-tag">LOSS</span>';
        return `<div class="hist-item">
          <div class="map-badge">${(m.mapName||'?').replace('de_','').toUpperCase()}</div>
          <div class="hist-vs">
            <span>${m.teamCT?.name||'CT'}</span>
            <span class="hist-score"><span class="ct-col">${m.teamCT?.score??0}</span> : <span class="t-col">${m.teamT?.score??0}</span></span>
            <span>${m.teamT?.name||'T'}</span>
          </div>
          ${resultTag}
          ${ps ? `<span class="hist-kda">${ps.kills}/${ps.deaths}/${ps.assists}</span>
                  <span style="color:var(--muted);font-size:0.7rem">ADR:${ps.adr}</span>
                  <span class="hist-rating">${ratingBar(ps.galaxyRating, 2)}</span>` : ''}
          <span class="hist-date">${ago(m.finishedAt)}</span>
        </div>`;
      }).join('') : '<div class="no-data">No match history yet</div>'}
    </div>
  `;
  document.getElementById('main').innerHTML = html;
}
</script>
</body>
</html>
