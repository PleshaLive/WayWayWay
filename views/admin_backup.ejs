    select:not(.select2-hidden-accessible) option { background-color: var(--color-surface-secondary); color: var(--color-text-primary); }
    input[type="file"] { padding-top: calc(var(--spacing-sm) - 1px); padding-bottom: calc(var(--spacing-sm) - 1px); }
    input[type="file"]::-webkit-file-upload-button { background: var(--color-primary-base); color: var(--color-text-on-primary); border: none; border-radius: var(--border-radius-sm); padding: var(--spacing-sm) var(--spacing-md); margin-right: var(--spacing-md); cursor: pointer; font-weight: var(--font-weight-medium); text-transform: uppercase; letter-spacing: 0.03em; transition: var(--transition-fast); box-shadow: 0 2px 5px rgba(var(--rgb-primary),0.2); }
    input[type="file"]::-webkit-file-upload-button:hover { background: var(--color-primary-light); box-shadow: var(--glow-primary); transform: translateY(-1px); }
    .app-button, button { 
        padding: var(--spacing-sm) var(--spacing-lg); 
        font-size: 0.85rem; 
        font-weight: var(--font-weight-semibold); 
        border-radius: var(--border-radius-lg); 
        border: 1px solid transparent; 
        background: linear-gradient(135deg, var(--color-primary-base), var(--color-primary-light));
        color: var(--color-text-on-primary); 
        cursor: pointer; 
        transition: var(--transition-base); 
        text-align: center; 
        line-height: 1.4; 
        letter-spacing: 0.02em; 
        min-width: 120px; 
        text-transform: uppercase; 
        box-shadow: 
            0 4px 15px rgba(var(--rgb-primary), 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
        position: relative; 
        overflow: hidden; 
        z-index: 1; 
        display: inline-flex; 
        align-items: center; 
        justify-content: center; 
        vertical-align: middle; 
        margin-top: var(--spacing-xs); 
        margin-bottom: var(--spacing-xs);
        backdrop-filter: blur(10px);
    }
    .app-button::before, button::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.1) 0%, 
            rgba(255, 255, 255, 0.05) 50%,
            transparent 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }
    .app-button::after, button::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.4s ease, height 0.4s ease;
        z-index: -1;
        opacity: 0;
    }
    a.app-button { text-decoration: none; }
    .app-button i, button i { margin-right: var(--spacing-sm); font-size: 0.9em; }
    .app-button:hover::before, button:hover::before { opacity: 1; }
    .app-button:hover::after, button:hover::after { width: 200%; height: 200%; opacity: 1; }
    .app-button.primary, button.primary { 
        background: linear-gradient(135deg, var(--color-primary-base), var(--color-primary-light)); 
        border-color: rgba(var(--rgb-primary), 0.3); 
    }
    .app-button.primary:hover, button.primary:hover { 
        transform: translateY(-3px) scale(1.02);
        box-shadow: 
            0 8px 25px rgba(var(--rgb-primary), 0.4),
            0 0 20px rgba(var(--rgb-primary), 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }
    .app-button.primary:active, button.primary:active { 
        transform: translateY(-1px) scale(1.01); 
        box-shadow: 
            0 4px 15px rgba(var(--rgb-primary), 0.3),
            inset 0 2px 5px rgba(0, 0, 0, 0.2);
    }
    .app-button.tertiary, button.tertiary { 
        background: linear-gradient(135deg, 
            rgba(var(--rgb-secondary), 0.1), 
            rgba(var(--rgb-secondary), 0.05)); 
        border: 1px solid rgba(var(--rgb-secondary), 0.3); 
        color: var(--color-secondary-light); 
        backdrop-filter: blur(10px);
    }
    .app-button.tertiary:hover, button.tertiary:hover { 
        background: linear-gradient(135deg, var(--color-secondary-base), var(--color-secondary-light)); 
        color: var(--color-text-on-accent); 
        border-color: var(--color-secondary-light);
        box-shadow: 
            0 8px 25px rgba(var(--rgb-secondary), 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }
    .app-button.small, button.small { padding: var(--spacing-xs) var(--spacing-sm); font-size: 0.75rem; min-width: auto; letter-spacing: 0.015em; }
    .app-button.small i, button.small i { margin-right: var(--spacing-xs); font-size: 0.85em; }
    .app-button.danger, button.danger { background-color: transparent; border-color: var(--color-error); color: var(--color-error); box-shadow: 0 2px 5px rgba(var(--rgb-error),0.2); }
    .app-button.danger:hover, button.danger:hover { background-color: var(--color-error); color: var(--color-text-on-accent); border-color: var(--color-error-dark); box-shadow: var(--glow-error), 0 0 12px rgba(var(--rgb-error),0.25) inset; }
    .app-button.success, button.success { background-color: #10B981; border-color: #10B981; color: white; box-shadow: 0 2px 5px rgba(16, 185, 129, 0.2); }
    .app-button.success:hover, button.success:hover { background-color: #059669; border-color: #059669; box-shadow: 0 0 16px rgba(16, 185, 129, 0.35), 0 0 12px rgba(16, 185, 129, 0.25) inset; transform: translateY(-2px) scale(1.015); }
    .app-button.success:active, button.success:active { transform: translateY(0px) scale(1); background-color: #047857; box-shadow: var(--shadow-inset); }
    .app-button.secondary, button.secondary { background-color: var(--color-secondary-base); border-color: var(--color-secondary-base); color: var(--color-text-on-accent); }
    .app-button.secondary:hover, button.secondary:hover { background-color: var(--color-secondary-light); border-color: var(--color-secondary-light); box-shadow: var(--glow-secondary), 0 0 12px rgba(var(--rgb-secondary),0.25) inset; }
    .top-buttons { text-align: center; margin-bottom: var(--spacing-lg); display: flex; justify-content: center; gap: var(--spacing-md); flex-wrap: wrap; }
    /* === КОНЕЦ ОСНОВНЫХ СТИЛЕЙ === */

    /* === Стили для сетки команд (макс. 6 колонок) === */
    .admin-teams-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-sm); margin-top: var(--spacing-lg); }
    @media (min-width: 768px) { .admin-teams-grid { grid-template-columns: repeat(3, 1fr); gap: var(--spacing-sm); } }
    @media (min-width: 992px) { .admin-teams-grid { grid-template-columns: repeat(4, 1fr); gap: var(--spacing-sm); } }
    @media (min-width: 1400px) { .admin-teams-grid { grid-template-columns: repeat(6, 1fr); gap: var(--spacing-sm); } }
    /* === Конец стилей для сетки === */

    /* === Компактные стили для карточки === */
    .team-card { 
        padding: var(--spacing-md);
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.04) 0%, 
            rgba(var(--rgb-secondary), 0.02) 100%);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--border-radius-xl);
        position: relative;
        overflow: hidden;
    }
    .team-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, 
            var(--color-primary-base), 
            var(--color-secondary-base), 
            var(--color-primary-base));
        opacity: 0.6;
    }
    .team-card::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: 
            radial-gradient(circle at center, 
                rgba(var(--rgb-primary), 0.03) 0%, 
                transparent 70%);
        animation: float 6s ease-in-out infinite;
        pointer-events: none;
    }
    @keyframes float {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(10px, -10px) rotate(1deg); }
        66% { transform: translate(-5px, 5px) rotate(-1deg); }
    }
    .team-card:hover {
        transform: translateY(-5px) scale(1.005); 
        box-shadow: 
            0 15px 50px rgba(0, 0, 0, 0.4),
            0 0 30px rgba(var(--rgb-primary), 0.2),
            inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }
    .team-card:hover::before {
        opacity: 1;
        box-shadow: 0 0 20px rgba(var(--rgb-primary), 0.5);
    }
    .team-card h2 { 
        font-size: 1.1rem; 
        margin-bottom: var(--spacing-xs); 
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        line-height: 1.3;
        background: linear-gradient(135deg, var(--color-text-primary), var(--color-primary-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
        z-index: 2;
    }
    .team-logo { 
        max-height: 60px; 
        margin-bottom: var(--spacing-sm); 
        object-fit: contain; 
        will-change: transform; 
        transition: transform 0.3s ease;
        filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.3));
        position: relative;
        z-index: 2;
    }
    .team-logo:hover { 
        transform: scale(1.08) rotate(2deg);
        filter: drop-shadow(0 6px 15px rgba(var(--rgb-primary), 0.4));
    }
    .team-card .no-logo-text { 
        text-align: center; 
        color: var(--color-text-muted); 
        margin-bottom: var(--spacing-sm); 
        font-style: italic; 
        font-size: 0.85rem;
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.05), 
            rgba(255, 255, 255, 0.02));
        padding: var(--spacing-sm);
        border-radius: var(--border-radius-md);
        border: 1px dashed rgba(255, 255, 255, 0.1);
    }
    /* НОВЫЙ СТИЛЬ: Информация для сортировки */
    .team-info-sort { 
        font-size: 0.72rem; 
        color: var(--color-text-muted); 
        margin-bottom: var(--spacing-sm); 
        line-height: 1.25;
        background: rgba(255, 255, 255, 0.03);
        padding: var(--spacing-xs);
        border-radius: var(--border-radius-sm);
        border-left: 2px solid rgba(var(--rgb-secondary), 0.3);
    }
    .team-info-sort span { display: block; }
    .team-actions { 
        gap: var(--spacing-xs); 
        margin-bottom: var(--spacing-sm); 
        flex-shrink: 0;
        position: relative;
        z-index: 2;
    }
    .team-actions .app-button.small { 
        font-size: 0.7rem; 
        padding: calc(var(--spacing-xs) - 1px);
        backdrop-filter: blur(5px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    /* === Конец компактных стилей === */

    /* === Стили для прокручиваемого списка игроков === */
    .team-card .player-list-wrapper { 
        max-height: 180px; 
        overflow-y: auto; 
        margin-top: auto; 
        padding-top: var(--spacing-sm); 
        border-top: 1px solid rgba(255, 255, 255, 0.1); 
        padding-right: var(--spacing-xs); 
        scrollbar-width: thin; 
        scrollbar-color: var(--color-primary-base) rgba(255, 255, 255, 0.05);
        position: relative;
        z-index: 2;
    }
    .team-card .player-list-wrapper::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, 
            transparent, 
            rgba(var(--rgb-primary), 0.3), 
            transparent);
    }
    .team-card .player-list-wrapper.styled-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
    .team-card .player-list-wrapper.styled-scrollbar::-webkit-scrollbar-track { 
        background: rgba(255, 255, 255, 0.05); 
        border-radius: var(--border-radius-sm); 
    }
    .team-card .player-list-wrapper.styled-scrollbar::-webkit-scrollbar-thumb { 
        background: linear-gradient(135deg, var(--color-primary-base), var(--color-primary-light)); 
        border-radius: var(--border-radius-sm); 
        box-shadow: 0 2px 5px rgba(var(--rgb-primary), 0.3);
    }
    .team-card .player-list-wrapper.styled-scrollbar::-webkit-scrollbar-thumb:hover { 
        background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary-base));
    }
    .team-card .players-list { margin-top: 0; padding-top: 0; border-top: none; padding-bottom: var(--spacing-xs); }
    .player-row:last-child { margin-bottom: 0; }
    .team-card .player-list-wrapper .no-players { 
        padding: var(--spacing-sm) 0; 
        text-align: center; 
        color: var(--color-text-muted); 
        font-style: italic; 
        font-size: 0.8rem;
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.02), 
            rgba(255, 255, 255, 0.01));
        border-radius: var(--border-radius-md);
        border: 1px dashed rgba(255, 255, 255, 0.1);
    }
    /* === Конец стилей для прокрутки === */

    /* === Стили для строки игрока === */
    .player-row { 
        padding: var(--spacing-xs) var(--spacing-sm); 
        display: flex; 
        align-items: center; 
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.05) 0%, 
            rgba(255, 255, 255, 0.02) 100%); 
        backdrop-filter: blur(5px);
        border-radius: var(--border-radius-md); 
        margin-bottom: var(--spacing-xs); 
        border: 1px solid rgba(255, 255, 255, 0.08); 
        transition: var(--transition-fast);
        position: relative;
        overflow: hidden;
    }
    .player-row::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(135deg, var(--color-primary-base), var(--color-secondary-base));
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .player-row:hover { 
        border-color: rgba(var(--rgb-primary), 0.3); 
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.08) 0%, 
            rgba(var(--rgb-primary), 0.04) 100%);
        transform: translateX(3px);
    }
    .player-row:hover::before {
        opacity: 1;
    }
    .player-photo img, .player-photo .no-photo-placeholder { 
        max-height: 32px; 
        width: 32px; 
        height: 32px; 
        font-size: 0.9rem; 
        margin-right: var(--spacing-sm); 
        border-radius: var(--border-radius-round); 
        border: 2px solid rgba(var(--rgb-primary), 0.2); 
        flex-shrink: 0; 
        will-change: transform; 
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }
    .player-photo img:hover { 
        transform: scale(1.15) rotate(5deg);
        border-color: rgba(var(--rgb-primary), 0.5);
        box-shadow: 0 4px 15px rgba(var(--rgb-primary), 0.4);
    }
    .player-photo .no-photo-placeholder { 
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.1), 
            rgba(var(--rgb-secondary), 0.05)); 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        color: var(--color-text-muted);
        backdrop-filter: blur(5px);
    }
    .player-name { 
        font-size: 0.8rem; 
        flex-grow: 1; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        white-space: nowrap; 
        color: var(--color-text-primary); 
        font-weight: var(--font-weight-medium);
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
    }
    .player-actions { 
        gap: var(--spacing-xs); 
        display: flex; 
        flex-shrink: 0; 
    }
    .player-actions .app-button.small i { margin-right: 0; }
    .player-actions .app-button.small { 
        min-width: auto; 
        padding: calc(var(--spacing-xs) - 1px); 
        line-height: 1; 
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(5px);
    }
    /* === Конец стилей строки игрока === */

    /* === Стили модальных окон === */
    .modal-backdrop { 
        position: fixed; 
        top: 0; 
        left: 0; 
        right: 0; 
        bottom: 0; 
        background: rgba(0, 0, 0, 0.4); 
        backdrop-filter: blur(12px); 
        -webkit-backdrop-filter: blur(12px);
        display: none; 
        justify-content: center; 
        align-items: center; 
        z-index: 9999; 
        padding: var(--spacing-md); 
        overflow-y: auto;
        animation: fadeInBackdrop 0.3s ease-out;
    }
    @keyframes fadeInBackdrop {
        from { opacity: 0; backdrop-filter: blur(0px); }
        to { opacity: 1; backdrop-filter: blur(12px); }
    }
    .modal { 
        width: 500px; 
        max-width: 95vw; 
        position: relative; 
        animation: modalSlideIn 0.4s cubic-bezier(0.25, 0.8, 0.25, 1) forwards; 
        max-height: 90vh; 
        display: flex; 
        flex-direction: column;
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.05) 0%, 
            rgba(var(--rgb-secondary), 0.03) 100%);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--border-radius-xl);
        box-shadow: 
            0 20px 60px rgba(0, 0, 0, 0.5),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        overflow: hidden;
    }
    .modal::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, 
            var(--color-primary-base), 
            var(--color-secondary-base), 
            var(--color-primary-base));
        animation: shimmer 2s infinite;
    }
    .modal-content { 
        overflow-y: auto; 
        padding: var(--spacing-lg) var(--spacing-xl); 
        padding-right: var(--spacing-lg); 
        flex-grow: 1;
        position: relative;
        z-index: 2;
    }
    @keyframes modalSlideIn { 
        0% { 
            transform: scale(0.9) translateY(30px); 
            opacity: 0; 
        } 
        100% { 
            transform: scale(1) translateY(0); 
            opacity: 1; 
        } 
    }
    .close-modal { 
        position: absolute; 
        top: var(--spacing-md); 
        right: var(--spacing-md); 
        background: rgba(255, 255, 255, 0.05); 
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1); 
        color: var(--color-text-muted); 
        font-size: 1.4rem; 
        line-height: 1; 
        cursor: pointer; 
        padding: var(--spacing-xs); 
        border-radius: var(--border-radius-round);
        transition: var(--transition-fast); 
        z-index: 10;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .close-modal:hover { 
        color: var(--color-error); 
        background: rgba(var(--rgb-error), 0.1);
        border-color: rgba(var(--rgb-error), 0.3);
        transform: scale(1.1) rotate(90deg);
    }
    .modal form { margin-top: var(--spacing-sm); }
    .modal .form-actions { 
        margin-top: var(--spacing-lg); 
        display: flex; 
        justify-content: flex-end; 
        gap: var(--spacing-sm); 
        padding-top: var(--spacing-md); 
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.02) 0%, 
            transparent 100%);
    }
    .modal #uploadTeamLogoBtn, .modal #uploadPlayerPhotoBtn { width: 100%; margin-bottom: var(--spacing-sm); }
    /* === Конец стилей модальных окон === */

    /* === Начало стилей для Select2 === */
    .select2-container { width: 100% !important; margin-bottom: var(--spacing-sm) !important; } /* Добавлен margin-bottom */
    .select2-container--default .select2-selection--single { background-color: var(--color-surface-tertiary); border: 1px solid var(--color-border); border-radius: var(--border-radius-md); height: calc(1.4em + var(--spacing-sm) * 2 + 2px); padding: 0 var(--spacing-md); /* Убрал верхний/нижний паддинг */ display: flex; align-items: center; transition: var(--transition-base); }
    .select2-container--default .select2-selection--single:focus,
    .select2-container--default.select2-container--open .select2-selection--single { border-color: var(--color-primary-light); box-shadow: 0 0 0 2px rgba(var(--rgb-primary), 0.25), var(--shadow-inset); outline: none; }
    .select2-container--default .select2-selection--single .select2-selection__rendered { color: var(--color-text-primary); line-height: 1.4; padding-left: 0; padding-right: 18px; font-size: 0.88rem; /* Место для стрелки */ }
    .select2-container--default .select2-selection--single .select2-selection__placeholder { color: var(--color-text-placeholder); }
    .select2-container--default .select2-selection--single .select2-selection__arrow { height: calc(1.4em + var(--spacing-sm) * 2); position: absolute; top: 1px; right: var(--spacing-sm); width: 18px; }
    .select2-container--default .select2-selection--single .select2-selection__arrow b { border-color: var(--color-text-muted) transparent transparent transparent; border-style: solid; border-width: 4px 3px 0 3px; height: 0; left: 50%; margin-left: -3px; margin-top: -2px; position: absolute; top: 50%; width: 0; }
    .select2-container--default.select2-container--open .select2-selection--single .select2-selection__arrow b { border-color: transparent transparent var(--color-text-muted) transparent; border-width: 0 3px 4px 3px; }
    .select2-dropdown { background-color: var(--color-surface-secondary); border: 1px solid var(--color-border-light); border-radius: var(--border-radius-md); box-shadow: var(--shadow-md); z-index: 10051; }
    .select2-container--default .select2-results__option { padding: var(--spacing-xs) var(--spacing-md); color: var(--color-text-secondary); font-size: 0.88rem; }
    .select2-container--default .select2-results__option--highlighted[aria-selected] { background-color: var(--color-primary-base); color: var(--color-text-on-primary); }
    .select2-results__option[aria-selected=true] { background-color: var(--color-surface-tertiary) !important; color: var(--color-text-primary) !important; }
    .select2-search--dropdown .select2-search__field { background-color: var(--color-surface-tertiary); border: 1px solid var(--color-border); color: var(--color-text-primary); border-radius: var(--border-radius-sm); padding: var(--spacing-xs); margin: var(--spacing-xs); width: calc(100% - var(--spacing-xs) * 2); font-size: 0.88rem; }
    .select2-search--dropdown .select2-search__field:focus { border-color: var(--color-primary-light); box-shadow: 0 0 0 2px rgba(var(--rgb-primary), 0.25), var(--shadow-inset); outline: none; }
    .select2-results__option .select2-results__group { color: var(--color-text-primary); font-weight: var(--font-weight-semibold); }
    /* Убираем стандартную стрелку у оригинального селекта, когда используется Select2 */
    select.select2-hidden-accessible { background-image: none !important; }
    /* === Конец стилей для Select2 === */

    /* === Адаптивность и Скроллбар === */
    @media (max-width: 768px) { 
        h1 { font-size: 1.5rem; } 
        .modal { width: 90vw; } 
        .page-title-container { justify-content: center; text-align: center; } 
        .admin-stats { justify-content: center; } 
        .container { padding: var(--spacing-sm) var(--spacing-md); }
    }
    @media (max-width: 480px) { 
        .container { padding: var(--spacing-sm); } 
        .top-buttons { flex-direction: column; gap: var(--spacing-sm); } 
        .top-buttons .app-button { width: 100%; } 
        .team-actions { flex-direction: column; gap: var(--spacing-xs); } 
        .team-actions .app-button { width: 100%; font-size: 0.7rem; } 
        .modal .form-actions { flex-direction: column; gap: var(--spacing-sm); } 
        .modal .form-actions .app-button { width: 100%; } 
        .page-title-container h1 { font-size: 1.3rem; } 
        .modal .modal-title-text { font-size: 1.25rem; } 
        .admin-stats { flex-direction: column; align-items: stretch; gap: var(--spacing-xs); } 
        .inline-sort-controls { justify-content: center; } 
        .admin-teams-grid { grid-template-columns: 1fr; gap: var(--spacing-sm); }
        .search-controls { flex-wrap: wrap; justify-content: center; }
        .search-input { min-width: 100px; flex: 1; }
    }
    .styled-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .styled-scrollbar::-webkit-scrollbar-track { background: var(--color-surface-secondary); border-radius: var(--border-radius-sm); }
    .styled-scrollbar::-webkit-scrollbar-thumb { background: var(--color-primary-base); border-radius: var(--border-radius-sm); border: 1px solid var(--color-surface-secondary); }
    .styled-scrollbar::-webkit-scrollbar-thumb:hover { background: var(--color-primary-light); }
    /* === Конец Адаптивности и Скроллбара === */

    /* === Стили для формы логина === */
    .login-card {
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.08) 0%, 
            rgba(var(--rgb-secondary), 0.05) 100%);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--border-radius-xl);
        padding: var(--spacing-xl);
        box-shadow: 
            0 20px 60px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        animation: loginCardFloat 6s ease-in-out infinite;
    }
    .login-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, 
            var(--color-primary-base), 
            var(--color-secondary-base), 
            var(--color-primary-base));
        animation: shimmer 3s infinite;
    }
    .login-card::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: 
            radial-gradient(circle at center, 
                rgba(var(--rgb-primary), 0.05) 0%, 
                transparent 70%);
        animation: loginFloat 8s ease-in-out infinite;
        pointer-events: none;
    }
    @keyframes loginCardFloat {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
    }
    @keyframes loginFloat {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(15px, -10px) rotate(2deg); }
        66% { transform: translate(-10px, 5px) rotate(-2deg); }
    }
    .login-header {
        text-align: center;
        margin-bottom: var(--spacing-xl);
        position: relative;
        z-index: 2;
    }
    .login-header h2 {
        font-size: 1.8rem;
        background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: var(--spacing-sm);
        filter: drop-shadow(0 2px 8px rgba(var(--rgb-primary), 0.3));
    }
    .login-header p {
        color: var(--color-text-secondary);
        font-size: 0.9rem;
        opacity: 0.8;
    }
    .input-group {
        margin-bottom: var(--spacing-lg);
        position: relative;
        z-index: 2;
    }
    .input-group label {
        margin-bottom: var(--spacing-sm);
        color: var(--color-text-secondary);
        font-size: 0.85rem;
    }
    .login-card .header-input {
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.05) 0%, 
            rgba(255, 255, 255, 0.02) 100%);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: var(--spacing-md);
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }
    .login-card .header-input:focus {
        background: linear-gradient(135deg, 
            rgba(var(--rgb-primary), 0.08) 0%, 
            rgba(var(--rgb-primary), 0.04) 100%);
        border-color: rgba(var(--rgb-primary), 0.4);
        box-shadow: 
            0 0 0 3px rgba(var(--rgb-primary), 0.2),
            0 8px 25px rgba(var(--rgb-primary), 0.15);
        transform: translateY(-2px);
    }
    .login-error {
        color: var(--color-error);
        text-align: center;
        margin: var(--spacing-md) 0;
        padding: var(--spacing-sm);
        background: linear-gradient(135deg, 
            rgba(var(--rgb-error), 0.1) 0%, 
            rgba(var(--rgb-error), 0.05) 100%);
        border: 1px solid rgba(var(--rgb-error), 0.2);
        border-radius: var(--border-radius-md);
        font-size: 0.85rem;
        display: none;
        position: relative;
        z-index: 2;
    }
    .login-btn {
        width: 100%;
        padding: var(--spacing-md) var(--spacing-lg);
        font-size: 0.9rem;
        position: relative;
        z-index: 2;
    }
    /* === Конец стилей для формы логина === */
  </style>
</head>
<body>
  <div id="loginSection" class="container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; position: relative;">
    <div class="login-card" style="width: 420px; max-width: 90%; position: relative; z-index: 2;">
      <div class="login-header">
        <h2><i class="fas fa-shield-alt"></i> Admin Portal</h2>
        <p>Access the control panel</p>
      </div>
      <form id="loginForm">
        <div class="input-group">
          <label for="username"><i class="fas fa-user"></i> Username:</label>
          <input type="text" id="username" name="username" required class="header-input" placeholder="Enter your username">
        </div>
        <div class="input-group">
          <label for="password"><i class="fas fa-key"></i> Password:</label>
          <input type="password" id="password" name="password" required class="header-input" placeholder="Enter your password">
        </div>
        <p id="loginError" class="login-error">Invalid login or password.</p>
        <div class="form-actions">
          <button type="submit" class="app-button primary login-btn"><i class="fas fa-sign-in-alt"></i> Sign In</button>
        </div>
      </form>
    </div>
  </div>

  <div id="adminSection" style="display: none;">
    <div class="container">
      <!-- Главный заголовок с навигацией -->
      <div class="main-header">
        <div class="header-left">
          <h1><i class="fas fa-shield-alt"></i> Admin Dashboard</h1>
          <p class="header-subtitle">Team & Player Management System</p>
        </div>
        <div class="header-right">
          <a href="https://galaxytimer-production.up.railway.app" class="quick-link">
            <i class="fas fa-external-link-alt"></i> Live Overlays
          </a>
        </div>
      </div>

      <!-- Панель статистики и управления -->
      <div class="control-panel">
        <div class="stats-section">
          <h3><i class="fas fa-chart-line"></i> Statistics</h3>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-users"></i></div>
              <div class="stat-content">
                <div class="stat-number"><%= teams.length %></div>
                <div class="stat-label">Teams</div>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon"><i class="fas fa-user-friends"></i></div>
              <div class="stat-content">
                <div class="stat-number"><%= players.length %></div>
                <div class="stat-label">Players</div>
              </div>
            </div>
          </div>
        </div>

        <div class="controls-section">
          <h3><i class="fas fa-sliders-h"></i> Controls</h3>
          <div class="controls-grid">
            <div class="control-group">
              <label><i class="fas fa-search"></i> Search Teams</label>
              <div class="search-wrapper">
                <input type="text" id="teamSearch" class="control-input" placeholder="Type team name..." autocomplete="off">
                <button type="button" class="clear-btn" title="Clear search">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>
            <div class="control-group">
              <label><i class="fas fa-sort"></i> Sort By</label>
              <select id="sortTeams" class="control-select">
                <option value="name">📝 Name (A-Z)</option>
                <option value="newest">� Newest First</option>
                <option value="oldest">� Oldest First</option>
                <option value="matches">� Most Matches</option>
              </select>
            </div>
          </div>
        </div>

        <div class="actions-section">
          <h3><i class="fas fa-plus"></i> Quick Actions</h3>
          <div class="action-buttons">
            <button id="btn-show-team-modal" class="action-btn primary">
              <i class="fas fa-users-cog"></i>
              <span>Create Team</span>
            </button>
            <button id="btn-show-player-modal" class="action-btn secondary">
              <i class="fas fa-user-plus"></i>
              <span>Add Player</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Секция команд -->
      <div class="teams-section">
        <div class="teams-header">
          <div class="teams-title">
            <h3>Teams Overview</h3>
            <span class="teams-count"><%= teams.length %></span>
          </div>
          <div class="teams-tools">
            <select id="sortTeams" class="sort-select">
              <option value="name">📝 Name (A-Z)</option>
              <option value="newest">📅 Newest First</option>
              <option value="oldest">📅 Oldest First</option>
              <option value="matches">📊 Most Matches</option>
            </select>
            <div class="view-toggle">
              <button class="view-btn active" data-view="grid">
                <i class="fas fa-th"></i> Grid
              </button>
              <button class="view-btn" data-view="list">
                <i class="fas fa-list"></i> List
              </button>
            </div>
          </div>
        </div>
        
        <div class="teams-container">
          <div class="teams-list">
            <% teams.forEach(team => {
              const teamPlayers = players.filter(p => p.teamId === team.id);
            %>
            <div class="team-card" data-team-id="<%= team.id %>">
              <div class="team-header">
                <img src="<%= team.logo || '/none.png' %>" alt="<%= team.name %>" class="team-logo" onerror="this.src='/none.png'">
                <div class="team-info">
                  <h4><%= team.name %></h4>
                  <div class="team-matches">
                    <span>📊</span>
                    <%= teamPlayers.length %> players
                  </div>
                </div>
              </div>
              <div class="team-actions">
                <button class="edit-btn" onclick="editTeam('<%= team.name %>')">
                  <span>✏️</span> Edit
                </button>
                <button class="delete-btn" onclick="deleteTeam('<%= team.name %>')">
                  <span>🗑️</span> Delete
                </button>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Модальные окна --> <div id="teamModalBackdrop" class="modal-backdrop">
      <div class="modal card-style">
        <button class="close-modal" id="closeTeamModal" aria-label="Close modal">&times;</button>
        <h2 id="teamModalTitle" class="modal-title-text"><i class="fas fa-users-cog"></i> Create Team</h2>
        <div class="modal-content styled-scrollbar">
          <form id="teamForm">
            <input type="hidden" name="id" id="teamId">
            <label for="teamName"><i class="fas fa-signature"></i> Team Name:</label>
            <input type="text" name="name" id="teamName" required class="header-input" placeholder="Enter team name">
            <label for="teamLogoFile"><i class="fas fa-image"></i> Logo File:</label>
            <input type="file" id="teamLogoFile" accept="image/*" class="header-input">
            <button type="button" id="uploadTeamLogoBtn" class="app-button tertiary" style="width:100%; margin-top: var(--spacing-xs); margin-bottom: var(--spacing-sm);"><i class="fas fa-upload"></i> Upload Selected Logo</button>
            <label for="teamLogo"><i class="fas fa-link"></i> Or Logo URL:</label>
            <input type="text" name="logo" id="teamLogo" class="header-input" placeholder="Enter logo URL (overrides file if both set)">
            <div class="form-actions">
              <button type="button" class="app-button tertiary" onclick="hideTeamModal()">Cancel</button>
              <button type="submit" class="app-button primary"><i class="fas fa-save"></i> Save Team</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div id="playerModalBackdrop" class="modal-backdrop">
      <div class="modal card-style">
        <button class="close-modal" id="closePlayerModal" aria-label="Close modal">&times;</button>
        <h2 id="playerModalTitle" class="modal-title-text"><i class="fas fa-user-plus"></i> Create Player</h2>
        <div class="modal-content styled-scrollbar">
          <form id="playerForm">
            <input type="hidden" name="id" id="playerId">
            <label for="playerName"><i class="fas fa-user-tag"></i> Player Name:</label>
            <input type="text" name="name" id="playerName" required class="header-input" placeholder="Enter player's name">
            <label for="playerSteamId"><i class="fab fa-steam-symbol"></i> Steam ID (Optional):</label>
            <input type="text" name="steamId" id="playerSteamId" class="header-input" placeholder="Enter Steam ID">
            <label for="playerPhotoFile"><i class="fas fa-portrait"></i> Photo File:</label>
            <input type="file" id="playerPhotoFile" accept="image/*" class="header-input">
            <button type="button" id="uploadPlayerPhotoBtn" class="app-button tertiary" style="width:100%; margin-top: var(--spacing-xs); margin-bottom: var(--spacing-sm);"><i class="fas fa-upload"></i> Upload Selected Photo</button>
            <label for="playerPhoto"><i class="fas fa-link"></i> Or Photo URL:</label>
            <input type="text" name="photo" id="playerPhoto" class="header-input" placeholder="Enter photo URL (overrides file if both set)">

            <label for="playerTeamId"><i class="fas fa-users"></i> Assign to Team:</label>
            <select id="playerTeamId" name="teamId" class="control-select" style="width: 100%;">
              <option value="">-- No Team --</option>
              <% teams.forEach(function(team){ %>
                <option value="<%= team.id %>" data-logo="<%= team.logo ? team.logo : '' %>">
                  <%= team.name %>
                </option>
              <% }); %>
            </select>
            <div class="form-actions">
              <button type="button" class="app-button tertiary" onclick="hidePlayerModal()">Cancel</button>
              <button type="submit" class="app-button primary"><i class="fas fa-save"></i> Save Player</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div> 
  <!-- <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script> -->

  <script>
    // Функции модальных окон (остаются глобально доступными)
    function showTeamModal(editMode = false, teamData = null) {$("#teamModalTitle").html(editMode ? '<i class="fas fa-edit"></i> Edit Team' : '<i class="fas fa-users-cog"></i> Create Team');$("#teamForm")[0].reset();$("#teamId").val("");$("#teamLogoFile").val('');if (editMode && teamData) {$("#teamId").val(teamData.id);$("#teamName").val(teamData.name);$("#teamLogo").val(teamData.logo); }$("#teamModalBackdrop").css("display","flex").hide().fadeIn(300);}
    function hideTeamModal() {$("#teamModalBackdrop").fadeOut(200, function() {$(this).hide();$("#teamForm")[0].reset();$("#teamId").val("");$("#teamLogoFile").val('');});}
    function showPlayerModal(editMode = false, playerData = null) {$("#playerModalTitle").html(editMode ? '<i class="fas fa-user-edit"></i> Edit Player' : '<i class="fas fa-user-plus"></i> Create Player');$("#playerForm")[0].reset();$("#playerId").val("");$("#playerPhotoFile").val(''); if (editMode && playerData) { $("#playerId").val(playerData.id); $("#playerName").val(playerData.name); $("#playerSteamId").val(playerData.steamId); $("#playerPhoto").val(playerData.photo); setTimeout(() => { $('#playerTeamId').val(playerData.teamId).trigger('change'); }, 50); } else { setTimeout(() => { $('#playerTeamId').val("").trigger('change'); }, 50); } $("#playerModalBackdrop").css("display","flex").hide().fadeIn(300);}
    function hidePlayerModal() {$("#playerModalBackdrop").fadeOut(200, function() {$(this).hide();$("#playerForm")[0].reset();$("#playerId").val("");$("#playerPhotoFile").val(''); $('#playerTeamId').val("").trigger('change'); });}

    // --- Login Logic ---
    const CORRECT_USERNAME = "admin";
    const CORRECT_PASSWORD = "admin";
    const STORAGE_KEY_LOGGED_IN = 'adminGalaxyTimerLoggedIn_v4'; // Новый ключ

    $(document).ready(function(){
        console.log("Document ready. Checking login status...");
        const isLoggedIn = localStorage.getItem(STORAGE_KEY_LOGGED_IN);
        console.log("localStorage status:", isLoggedIn);

        if (isLoggedIn === 'true') {
            console.log("User is logged in. Showing admin panel.");
            $("#loginSection").hide();
            $("#adminSection").show();
        } else {
            console.log("User is NOT logged in. Showing login form.");
            $("#loginSection").show();
            $("#adminSection").hide();
        }

        $("#loginForm").submit(function(e) {
            e.preventDefault();
            console.log("Login form submitted.");
            const username = $("#username").val();
            const password = $("#password").val();

            if (username === CORRECT_USERNAME && password === CORRECT_PASSWORD) {
                console.log("Login successful.");
                localStorage.setItem(STORAGE_KEY_LOGGED_IN, 'true');
                $("#loginSection").fadeOut(300, function() {
                    $("#adminSection").fadeIn(300);
                });
                $("#loginError").hide();
            } else {
                console.log("Login failed.");
                localStorage.removeItem(STORAGE_KEY_LOGGED_IN);
                $("#loginError").show().html('<i class="fas fa-exclamation-triangle"></i> Invalid credentials. Please try again.');
            }
        });
    });
    
    // Простые функции для кнопок
    window.logout = function() {
        localStorage.removeItem('adminGalaxyTimerLoggedIn_v4');
        location.reload();
    };

    window.editTeam = function(teamName) {
        alert('Edit team: ' + teamName);
    };

    window.deleteTeam = function(teamName) {
        if (confirm('Delete team: ' + teamName + '?')) {
            alert('Team deleted (demo)');
        }
    };
  </script>
</body>
</html>

        $("#closeTeamModal").off('click').on('click', function(){ hideTeamModal(); });
        $("#closePlayerModal").off('click').on('click', function(){ hidePlayerModal(); });
        $(document).off("click", ".modal-backdrop").on("click", ".modal-backdrop", function(event) { if ($(event.target).is(".modal-backdrop")) { if ($("#teamModalBackdrop").is(":visible")) { hideTeamModal(); } if ($("#playerModalBackdrop").is(":visible")) { hidePlayerModal(); } } });

        // AJAX Запросы
        $("#uploadTeamLogoBtn").off('click').on('click', function(){
            const fileInput = $("#teamLogoFile")[0];
            if (!fileInput.files.length) {
                alert("Please select a logo file first.");
                return;
            }
            
            const formData = new FormData();
            formData.append('logoFile', fileInput.files[0]);
            
            $.ajax({
                url: '/api/teams/uploadLogo',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function(response) {
                    $("#teamLogo").val(response.path);
                    alert("Logo uploaded. Path: " + response.path + "\nClick 'Save Team' to apply changes.");
                },
                error: function() {
                    alert("Error uploading logo. Please try again or enter URL manually.");
                }
            });
        });
        
        $("#uploadPlayerPhotoBtn").off('click').on('click', function(){
            const fileInput = $("#playerPhotoFile")[0];
            if (!fileInput.files.length) {
                alert("Please select a photo file first.");
                return;
            }
            
            const formData = new FormData();
            formData.append('photoFile', fileInput.files[0]);
            
            $.ajax({
                url: '/api/players/uploadPhoto',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function(response) {
                    $("#playerPhoto").val(response.path);
                    alert("Photo uploaded. Path: " + response.path + "\nClick 'Save Player' to apply changes.");
                },
                error: function() {
                    alert("Error uploading photo. Please try again or enter URL manually.");
                }
            });
        });
        $("#teamForm").off('submit').on('submit', function(e){ 
            e.preventDefault(); 
            const id = $("#teamId").val(); 
            const name = $("#teamName").val(); 
            const logo = $("#teamLogo").val(); 
            const url = id ? "/api/teams/" + id : "/api/teams"; 
            const type = id ? "PUT" : "POST"; 
            const data = { name, logo }; 
            $.ajax({ 
                url: url, 
                type: type, 
                data: data, 
                success: function(){ 
                    hideTeamModal(); 
                    location.reload(); 
                }, 
                error: function(xhr) { 
                    alert("Error saving team: " + (xhr.responseJSON ? xhr.responseJSON.message : xhr.statusText));
                } 
            }); 
        });
        
        $("#playerForm").off('submit').on('submit', function(e){ 
            e.preventDefault(); 
            const id = $("#playerId").val(); 
            const name = $("#playerName").val(); 
            const steamId = $("#playerSteamId").val(); 
            const photo = $("#playerPhoto").val(); 
            const teamId = $("#playerTeamId").val() || null; 
            const url = id ? "/api/players/" + id : "/api/players"; 
            const type = id ? "PUT" : "POST"; 
            $.ajax({ 
                url: url, 
                type: type, 
                data: { name, steamId, photo, teamId }, 
                success: function(){ 
                    hidePlayerModal(); 
                    location.reload(); 
                }, 
                error: function(xhr) { 
                    alert("Error saving player: " + (xhr.responseJSON ? xhr.responseJSON.message : xhr.statusText));
                } 
            }); 
        });

        // Редактирование и удаление команд
        $(document).off("click", ".editTeam").on("click", ".editTeam", function(){ 
            const teamId = $(this).closest(".team-card").data("id"); 
            $.get("/api/teams/" + teamId, function(team){ 
                if(team){ 
                    showTeamModal(true, team); 
                } else { 
                    alert("Team data not found."); 
                } 
            }).fail(function(){ 
                alert("Could not fetch team data for editing."); 
            }); 
        });
        
        $(document).off("click", ".deleteTeam").on("click", ".deleteTeam", function(){ 
            const card = $(this).closest(".team-card"); 
            const teamName = card.find("h2").text(); 
            const teamId = card.data("id"); 
            if(confirm("Are you sure you want to delete team '" + teamName + "'? This will also unassign its players.")){ 
                $.ajax({ 
                    url: "/api/teams/" + teamId, 
                    type: "DELETE", 
                    success: function(){ 
                        location.reload(); 
                    }, 
                    error: function(xhr) { 
                        alert("Error deleting team: " + (xhr.responseJSON ? xhr.responseJSON.message : xhr.statusText));
                    } 
                }); 
            } 
        });
        
        // Редактирование и удаление игроков
        $(document).off("click", ".editPlayer").on("click", ".editPlayer", function(){
            const playerId = $(this).closest(".player-row").data("id");
            
            // Сначала загружаем команды для селекта
            $.get("/api/teams", function(teams) {
                const teamSelect = $("#playerTeamId");
                teamSelect.empty();
                teamSelect.append(new Option("-- No Team --", "", false, false));
                teams.forEach(function(team) {
                    const option = new Option(team.name, team.id, false, false);
                    teamSelect.append(option);
                });
                
                // Затем загружаем данные игрока
                $.get("/api/players/" + playerId, function(player){ 
                    if(player){ 
                        showPlayerModal(true, player); 
                    } else { 
                        alert("Player data not found."); 
                    } 
                }).fail(function(){ 
                    alert("Could not fetch player data for editing."); 
                });
            }).fail(function() { 
                alert("Could not load teams. Player data might be incomplete."); 
            });
        });
        
        $(document).off("click", ".deletePlayer").on("click", ".deletePlayer", function(){ 
            const row = $(this).closest(".player-row"); 
            const playerName = row.find(".player-name").text(); 
            const playerId = row.data("id"); 
            if(confirm("Are you sure you want to delete player '" + playerName + "'?")){ 
                $.ajax({ 
                    url: "/api/players/" + playerId, 
                    type: "DELETE", 
                    success: function(){ 
                        location.reload(); 
                    }, 
                    error: function(xhr) { 
                        alert("Error deleting player: " + (xhr.responseJSON ? xhr.responseJSON.message : xhr.statusText));
                    } 
                }); 
            } 
        });

        // === Начало: Логика сортировки и поиска команд ===
        console.log("Setting up sorting and search logic...");
        function sortAndDisplayTeams() {
            console.log("Sorting and filtering teams...");
            const sortBy = $('#sortTeams').val() || 'name';
            const searchTerm = $('#teamSearch').val().toLowerCase().trim();
            const teamsContainer = $('.teams-list');
            let teamCards = teamsContainer.find('.team-card').get();
            
            // Фильтрация по поиску
            let filteredCards = teamCards;
            if (searchTerm) {
                filteredCards = teamCards.filter(function(card) {
                    const teamName = $(card).find('h4').text().toLowerCase();
                    return teamName.includes(searchTerm);
                });
            }
            
            // Сортировка отфильтрованных карточек
            filteredCards.sort(function(a, b) {
                let valA, valB;
                const nameA = $(a).find('h4').text();
                const nameB = $(b).find('h4').text();
                const matchesA = parseInt($(a).find('.team-matches').text().match(/\d+/) || [0]);
                const matchesB = parseInt($(b).find('.team-matches').text().match(/\d+/) || [0]);
                
                switch (sortBy) {
                    case 'name': 
                        return nameA.localeCompare(nameB);
                    case 'newest':
                    case 'oldest':
                        // Для простоты сортируем по имени
                        return nameA.localeCompare(nameB);
                    case 'matches':
                        return matchesB - matchesA;
                    default: 
                        return nameA.localeCompare(nameB);
                }
            });
            
            // Скрытие всех карточек
            $(teamCards).hide();
            
            // Показ отфильтрованных карточек
            teamsContainer.empty();
            if (filteredCards.length > 0) {
                $.each(filteredCards, function(i, card) { 
                    $(card).show();
                    teamsContainer.append(card); 
                });
            } else if (searchTerm) {
                // Показать сообщение о том, что ничего не найдено
                teamsContainer.html(`
                    <div class="empty-state">
                        <div class="empty-icon">🔍</div>
                        <div class="empty-title">Команды не найдены</div>
                        <div class="empty-description">Попробуйте изменить поисковый запрос</div>
                    </div>
                `);
            } else {
                // Показать все карточки если поиск пустой
                $.each(teamCards, function(i, card) { 
                    $(card).show();
                    teamsContainer.append(card); 
                });
            }
            
            // Обновить счетчики
            updateCounters();
        }
                    teamsGrid.append(card); 
                });
            }
            
            // Обновить счетчики
            updateCounters();
        }
        
        // Обработчики событий
        $('#sortTeams').off('change').on('change', function() { sortAndDisplayTeams(); });
        
        // Поиск в реальном времени
        $('#teamSearch').off('input').on('input', function() { 
            const searchValue = $(this).val();
            const clearBtn = $('.clear-btn');
            
            if (searchValue.trim()) {
                clearBtn.addClass('visible');
            } else {
                clearBtn.removeClass('visible');
            }
            
            sortAndDisplayTeams(); 
        });
        
        // Кнопка очистки поиска
        $('.clear-btn').off('click').on('click', function() {
            $('#teamSearch').val('').trigger('input');
            $(this).removeClass('visible');
        });
        
        if ($('#teamsGrid .team-card').length > 0) { sortAndDisplayTeams(); }
        // === Конец: Логика сортировки и поиска команд ===
        
        // === Функции для кнопок действий ===
        window.openAddTeamModal = function() {
            showTeamModal(false);
        };
        
        window.openEditTeamModal = function() {
            // Здесь можно добавить логику выбора команды для редактирования
            alert('Выберите команду для редактирования из списка ниже');
        };
        
        window.editTeam = function(teamName) {
            // Найти данные команды из существующих карточек
            const teamCards = document.querySelectorAll('.team-card');
            let teamData = null;
            
            teamCards.forEach(card => {
                const cardTeamName = card.querySelector('h4').textContent;
                if (cardTeamName === teamName) {
                    const logo = card.querySelector('.team-logo').src;
                    teamData = {
                        name: teamName,
                        logo: logo
                    };
                }
            });
            
            if (teamData) {
                showTeamModal(true, teamData);
            }
        };
        
        window.deleteTeam = function(teamName) {
            if (confirm(`Вы уверены, что хотите удалить команду "${teamName}"?`)) {
                fetch('/delete-team', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ teamName: teamName })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Ошибка при удалении команды: ' + (data.error || 'Неизвестная ошибка'));
                    }
                })
                .catch(error => {
                    console.error('Ошибка:', error);
                    alert('Ошибка при удалении команды');
                });
            }
        };
        
        // === Переключение видов (если понадобится в будущем) ===
        $('.view-btn').off('click').on('click', function() {
            $('.view-btn').removeClass('active');
            $(this).addClass('active');
            
            const view = $(this).data('view');
            if (view === 'list') {
                $('.teams-list').addClass('list-view');
            } else {
                $('.teams-list').removeClass('list-view');
            }
        });
        
        // === Обновление счетчиков при инициализации ===
        updateCounters();
        
        // === Функция обновления счетчиков ===
        function updateCounters() {
          const visibleTeamsCount = $('.teams-list .team-card:visible').length;
          const totalTeamsCount = $('.teams-list .team-card').length;
          const playersCount = $('.player-row').length;
          
          // Обновляем счетчик команд с индикацией фильтрации
          const searchTerm = $('#teamSearch').val().trim();
          if (searchTerm && visibleTeamsCount !== totalTeamsCount) {
            $('.teams-count').html(`${visibleTeamsCount}/${totalTeamsCount}`);
          } else {
            $('.teams-count').text(totalTeamsCount);
          }
          
          // Обновляем статистику в панели управления
          $('.stat-number').eq(0).text(totalTeamsCount);
          $('.stat-number').eq(1).text(playersCount);
          
          console.log(`Counters updated: ${visibleTeamsCount}/${totalTeamsCount} teams, ${playersCount} players`);
        }
        
        console.log("Admin Panel Initialized.");
      } // Конец initializeAdminPanel
    }); // Конец document.ready
  </script>
</body>
</html>