  noEl.style.display = 'none';
  const sorted = [...data].sort((a,b) => (a[sortCol]??0)<(b[sortCol]??0) ? sortDir : -sortDir);
  tbody.innerHTML = sorted.map((p, i) => {
    const rankC = i===0?'g1':i===1?'g2':i===2?'g3':'';
