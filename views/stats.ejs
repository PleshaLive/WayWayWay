<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galaxy Stats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
  <style>
  :root {
    --bg:        #09071a;
    --surface:   #110e27;
    --surface2:  #18143a;
    --surface3:  #1f1a46;
    --border:    rgba(99,102,241,0.15);
    --border2:   rgba(255,255,255,0.055);
    --text:      #e8e4ff;
    --text2:     #9490b8;
    --muted:     #514c6e;
    --primary:   #6366f1;
    --prim-glow: rgba(99,102,241,0.35);
    --ct:        #38bdf8;
    --ct-bg:     rgba(56,189,248,0.07);
    --t:         #f59e0b;
    --t-bg:      rgba(245,158,11,0.07);
    --success:   #34d399;
    --danger:    #f87171;
    --gold:      #fbbf24;
    --gold-bg:   rgba(251,191,36,0.08);
    --silver:    #94a3b8;
    --bronze:    #cd7f32;
    --r:         10px;
    --r-lg:      16px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    background-image:
      radial-gradient(ellipse 80% 40% at 50% -10%, rgba(79,70,229,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 90% 100%, rgba(56,189,248,0.04) 0%, transparent 50%);
  }

  /* ─── Scrollbar ─────────────────────────────────────────── */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.35); border-radius: 4px; }

  /* ─── Header ─────────────────────────────────────────────── */
  .site-header {
    position: sticky; top: 0; z-index: 200;
    background: rgba(9,7,26,0.85);
    backdrop-filter: blur(24px) saturate(180%);
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    height: 56px;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .header-logo {
    display: flex; align-items: center; gap: 0.75rem;
    text-decoration: none;
  }
  .logo-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; color: #fff;
    box-shadow: 0 0 16px rgba(99,102,241,0.4);
    flex-shrink: 0;
  }
  .logo-text { font-size: 1rem; font-weight: 800; color: var(--text); letter-spacing: -0.01em; }
  .logo-text span { color: var(--primary); }
  .header-right { display: flex; align-items: center; gap: 0.5rem; }
  .header-update { font-size: 0.67rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; margin-right: 0.5rem; }
  .hbtn {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.35rem 0.8rem; font-size: 0.72rem; font-weight: 600;
    border-radius: 6px; border: 1px solid var(--border2);
    background: rgba(255,255,255,0.04); color: var(--text2);
    cursor: pointer; text-decoration: none; transition: all 0.15s;
    letter-spacing: 0.03em;
  }
  .hbtn:hover { background: rgba(99,102,241,0.1); border-color: var(--border); color: var(--text); }

  /* ─── Layout ─────────────────────────────────────────────── */
  .page { max-width: 1700px; margin: 0 auto; padding: 1.4rem 1.4rem 3rem; }

  /* ─── Nav Tabs ───────────────────────────────────────────── */
  .nav-tabs {
    display: flex; gap: 0.25rem; margin-bottom: 1.6rem;
    background: rgba(17,14,39,0.7);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 0.3rem;
    overflow-x: auto; scrollbar-width: none;
    backdrop-filter: blur(12px);
  }
  .nav-tabs::-webkit-scrollbar { display: none; }
  .nav-tab {
    flex-shrink: 0;
    display: flex; align-items: center; gap: 0.45rem;
    padding: 0.52rem 1.1rem; font-size: 0.76rem; font-weight: 600;
    border-radius: 8px; border: none; background: transparent;
    color: var(--text2); cursor: pointer; transition: all 0.2s;
    letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap;
  }
  .nav-tab:hover { background: rgba(99,102,241,0.1); color: var(--text); }
  .nav-tab.active {
    background: linear-gradient(135deg, rgba(79,70,229,0.35) 0%, rgba(99,102,241,0.2) 100%);
    color: #c4b5fd; border: 1px solid rgba(99,102,241,0.3);
    box-shadow: 0 0 20px rgba(99,102,241,0.15), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .nav-tab .tab-icon { font-size: 0.8rem; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; animation: panelIn 0.22s ease; }
  @keyframes panelIn { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform:none; } }

  /* ─── Cards ─────────────────────────────────────────────── */
  .card {
    background: rgba(17,14,39,0.65);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    backdrop-filter: blur(16px);
    overflow: hidden;
  }
  .card-header {
    padding: 0.9rem 1.2rem;
    border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap;
  }
  .card-title {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text2);
    display: flex; align-items: center; gap: 0.45rem;
  }
  .card-title i { color: var(--primary); }

  /* ─── MATCH TAB ─────────────────────────────────────────── */
  .match-no-data {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 1rem;
    min-height: 340px; color: var(--muted);
  }
  .match-no-data .ndi { font-size: 3.5rem; opacity: 0.15; }
  .match-no-data p { font-size: 0.9rem; font-style: italic; }

  /* Score Banner */
  .score-banner {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, #0d0b23 0%, #111030 100%);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    margin-bottom: 1rem;
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .score-banner::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 100% at 50% 0%, rgba(99,102,241,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .sb-team {
    padding: 1.8rem 2rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
  }
  .sb-team.ct-side { background: linear-gradient(135deg, rgba(56,189,248,0.06) 0%, transparent 60%); }
  .sb-team.t-side  { background: linear-gradient(135deg, transparent 40%, rgba(245,158,11,0.06) 100%); }
  .sb-logo { width: 72px; height: 72px; object-fit: contain; filter: drop-shadow(0 4px 16px rgba(0,0,0,0.4)); }
  .sb-logo-ph {
    width: 72px; height: 72px; border-radius: 12px;
    background: rgba(255,255,255,0.04); border: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: var(--muted);
  }
  .sb-team-name {
    font-size: 1rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.08em; text-align: center;
  }
  .sb-team-side {
    font-size: 0.62rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 0.15rem 0.6rem;
    border-radius: 50px; border: 1px solid;
  }
  .sb-team-side.ct { color: var(--ct); border-color: rgba(56,189,248,0.3); background: rgba(56,189,248,0.08); }
  .sb-team-side.t  { color: var(--t);  border-color: rgba(245,158,11,0.3);  background: rgba(245,158,11,0.08); }
  .sb-center {
    display: flex; flex-direction: column; align-items: center;
    padding: 1.8rem 2.5rem; gap: 0.5rem; flex-shrink: 0;
  }
  .sb-scores {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 4rem; font-weight: 900; line-height: 1;
    letter-spacing: -0.03em;
  }
  .sb-scores .ct-s { color: var(--ct); text-shadow: 0 0 30px rgba(56,189,248,0.4); }
  .sb-scores .t-s  { color: var(--t);  text-shadow: 0 0 30px rgba(245,158,11,0.4); }
  .sb-scores .sep  { color: var(--muted); font-weight: 300; font-size: 3rem; }
  .sb-map {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--primary);
    background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);
    border-radius: 6px; padding: 0.2rem 0.75rem;
  }
  .sb-rounds { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.08em; }
  .live-badge {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem; border-radius: 50px;
    background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.35);
    color: #f87171; animation: pulseBorder 1.8s infinite;
  }
  .live-dot { width: 5px; height: 5px; border-radius: 50%; background: #ef4444; animation: pulseDot 1.2s infinite; }
  @keyframes pulseDot    { 0%,100%{opacity:1} 50%{opacity:.25} }
  @keyframes pulseBorder { 0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0.2)} 50%{box-shadow:0 0 0 5px rgba(239,68,68,0)} }

  /* Player Cards grid in match */
  .match-sides { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media(max-width:880px){ .match-sides { grid-template-columns: 1fr; } }
  .match-side-card { border-radius: var(--r-lg); overflow: hidden; border: 1px solid; }
  .match-side-card.ct-card { border-color: rgba(56,189,248,0.2); background: linear-gradient(180deg, rgba(56,189,248,0.04) 0%, rgba(17,14,39,0.7) 100%); }
  .match-side-card.t-card  { border-color: rgba(245,158,11,0.2);  background: linear-gradient(180deg, rgba(245,158,11,0.04)  0%, rgba(17,14,39,0.7) 100%); }
  .side-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 1rem; border-bottom: 1px solid var(--border2);
  }
  .side-label {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .side-label.ct { color: var(--ct); }
  .side-label.t  { color: var(--t); }

  /* Player row with large photo */
  .player-rows { display: flex; flex-direction: column; }
  .player-row {
    display: grid;
    grid-template-columns: 52px 1fr 44px 44px 44px 56px 56px 60px 90px;
    align-items: center; gap: 0.3rem;
    padding: 0.55rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.025);
    transition: background 0.12s;
  }
  .player-row:last-child { border-bottom: none; }
  .player-row:hover { background: rgba(255,255,255,0.025); }
  .player-row-ph { /* column headers row */
    grid-template-columns: 52px 1fr 44px 44px 44px 56px 56px 60px 90px;
    padding: 0.35rem 1rem;
    background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border2);
    display: grid; align-items: center; gap: 0.3rem;
  }
  .player-row-ph span {
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--muted); text-align: right;
  }
  .player-row-ph span:first-child { text-align: left; grid-column: 1/3; }
  .pr-avatar {
    width: 44px; height: 44px; border-radius: 10px;
    object-fit: cover; border: 2px solid rgba(255,255,255,0.07);
    background: rgba(0,0,0,0.3);
    flex-shrink: 0;
  }
  .pr-avatar-ph {
    width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0;
    background: rgba(79,70,229,0.12); border: 2px solid rgba(99,102,241,0.15);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; color: var(--muted);
  }
  .pr-info { min-width: 0; overflow: hidden; }
  .pr-name {
    font-size: 0.84rem; font-weight: 700; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; color: var(--text);
    text-decoration: none; display: block;
  }
  .pr-name:hover { color: var(--primary); }
  .pr-tag { font-size: 0.62rem; color: var(--muted); margin-top: 0.05rem; }
  .pr-num { text-align: right; font-size: 0.82rem; font-weight: 600; color: var(--text2); }
  .pr-num.hi { color: var(--text); font-weight: 700; }
  .pr-num.good { color: var(--success); }
  .pr-num.bad  { color: var(--danger); }
  .pr-num.gold { color: var(--gold); }

  /* Mini rating bar */
  .mini-rating { display: flex; align-items: center; gap: 0.35rem; justify-content: flex-end; }
  .mini-bar { width: 36px; height: 3px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
  .mini-fill { height: 100%; border-radius: 2px; }
  .mini-val  { font-size: 0.78rem; font-weight: 800; min-width: 32px; text-align: right; }

  /* ─── LEADERBOARD TAB ───────────────────────────────────── */
  .podium-row {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.4rem;
  }
  @media(max-width:600px){ .podium-row { grid-template-columns: 1fr; } }
  .podium-card {
    position: relative; overflow: hidden;
    border-radius: var(--r-lg); border: 1px solid var(--border);
    background: rgba(17,14,39,0.8);
    display: flex; flex-direction: column; align-items: center;
    padding: 1.6rem 1rem 1.2rem; gap: 0.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .podium-card:hover { transform: translateY(-3px); }
  .podium-card.rank-1 {
    border-color: rgba(251,191,36,0.35);
    background: linear-gradient(180deg, rgba(251,191,36,0.06) 0%, rgba(17,14,39,0.8) 50%);
    box-shadow: 0 8px 40px rgba(251,191,36,0.1);
  }
  .podium-card.rank-2 {
    border-color: rgba(148,163,184,0.25);
    background: linear-gradient(180deg, rgba(148,163,184,0.04) 0%, rgba(17,14,39,0.8) 50%);
  }
  .podium-card.rank-3 {
    border-color: rgba(205,127,50,0.25);
    background: linear-gradient(180deg, rgba(205,127,50,0.04) 0%, rgba(17,14,39,0.8) 50%);
  }
  .podium-rank {
    position: absolute; top: 0.7rem; right: 0.8rem;
    font-size: 1.4rem; font-weight: 900; opacity: 0.15;
  }
  .rank-1 .podium-rank { color: var(--gold); opacity: 0.5; }
  .podium-avatar {
    width: 72px; height: 72px; border-radius: 50%;
    object-fit: cover; border: 3px solid rgba(255,255,255,0.1);
    background: rgba(0,0,0,0.3);
  }
  .podium-avatar-ph {
    width: 72px; height: 72px; border-radius: 50%;
    background: rgba(79,70,229,0.12); border: 3px solid rgba(99,102,241,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: var(--muted);
  }
  .rank-1 .podium-avatar, .rank-1 .podium-avatar-ph { border-color: rgba(251,191,36,0.45); }
  .rank-2 .podium-avatar, .rank-2 .podium-avatar-ph { border-color: rgba(148,163,184,0.4); }
  .rank-3 .podium-avatar, .rank-3 .podium-avatar-ph { border-color: rgba(205,127,50,0.4); }
  .podium-name {
    font-size: 0.95rem; font-weight: 800; text-align: center;
    color: var(--text); text-decoration: none;
  }
  .podium-name:hover { color: var(--primary); }
  .podium-rating {
    font-size: 1.6rem; font-weight: 900;
    line-height: 1;
  }
  .podium-label { font-size: 0.6rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .podium-stats { display: flex; gap: 1rem; margin-top: 0.2rem; }
  .podium-stat { text-align: center; }
  .podium-stat-val { font-size: 0.88rem; font-weight: 700; }
  .podium-stat-lbl { font-size: 0.58rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .crown { position: absolute; top: -4px; left: 50%; transform: translateX(-50%); font-size: 1.4rem; filter: drop-shadow(0 2px 8px rgba(251,191,36,0.6)); }

  /* Leaderboard table */
  .lb-table { width: 100%; border-collapse: collapse; }
  .lb-table th {
    padding: 0.5rem 0.8rem; text-align: left;
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--border2); white-space: nowrap; cursor: pointer;
    user-select: none;
  }
  .lb-table th:hover { color: var(--text2); }
  .lb-table th.sort-asc::after  { content: ' ↑'; color: var(--primary); }
  .lb-table th.sort-desc::after { content: ' ↓'; color: var(--primary); }
  .lb-table th.r, .lb-table td.r { text-align: right; }
  .lb-table td { padding: 0.6rem 0.8rem; border-bottom: 1px solid rgba(255,255,255,0.025); vertical-align: middle; }
  .lb-table tr:last-child td { border-bottom: none; }
  .lb-table tbody tr { transition: background 0.1s; }
  .lb-table tbody tr:hover td { background: rgba(99,102,241,0.045); }
  .lb-rank { font-size: 0.75rem; font-weight: 800; color: var(--muted); min-width: 24px; text-align: center; }
  .lb-rank.g1 { color: var(--gold); }
  .lb-rank.g2 { color: var(--silver); }
  .lb-rank.g3 { color: var(--bronze); }
  .lb-player { display: flex; align-items: center; gap: 0.65rem; }
  .lb-avatar {
    width: 38px; height: 38px; border-radius: 8px; object-fit: cover;
    border: 1.5px solid rgba(255,255,255,0.07); background: rgba(0,0,0,0.3); flex-shrink: 0;
  }
  .lb-avatar-ph {
    width: 38px; height: 38px; border-radius: 8px; flex-shrink: 0;
    background: rgba(79,70,229,0.1); border: 1.5px solid rgba(99,102,241,0.15);
    display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--muted);
  }
  .lb-pname { font-weight: 600; font-size: 0.82rem; color: var(--text); text-decoration: none; white-space: nowrap; }
  .lb-pname:hover { color: var(--primary); }
  .lb-msub { font-size: 0.6rem; color: var(--muted); }
  .lb-val { font-size: 0.8rem; font-weight: 600; color: var(--text2); }
  .lb-val.acc { color: var(--text); font-weight: 700; }
  .lb-val.g { color: var(--success); }
  .lb-val.b { color: var(--danger); }
  .lb-rating { display: flex; align-items: center; gap: 0.4rem; justify-content: flex-end; }
  .lb-rbar { width: 40px; height: 3px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
  .lb-rfill { height: 100%; border-radius: 2px; }
  .lb-rval { font-size: 0.8rem; font-weight: 800; min-width: 34px; text-align: right; }

  /* ─── TEAM TAB ───────────────────────────────────────────── */
  .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px,1fr)); gap: 1rem; }
  .team-card {
    border-radius: var(--r-lg); border: 1px solid var(--border);
    background: rgba(17,14,39,0.7);
    overflow: hidden; transition: border-color 0.2s, transform 0.2s;
    cursor: pointer; text-decoration: none; display: block; color: inherit;
  }
  .team-card:hover { border-color: rgba(99,102,241,0.35); transform: translateY(-2px); }
  .team-card-top {
    padding: 1.2rem 1.2rem 0.8rem;
    display: flex; align-items: center; gap: 0.9rem;
  }
  .tc-logo { width: 48px; height: 48px; object-fit: contain; flex-shrink: 0; }
  .tc-logo-ph {
    width: 48px; height: 48px; border-radius: 10px; flex-shrink: 0;
    background: rgba(79,70,229,0.08); border: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 1.1rem;
  }
  .tc-name  { font-size: 0.95rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .tc-sub   { font-size: 0.65rem; color: var(--muted); margin-top: 0.1rem; }
  .tc-winrate { margin-left: auto; font-size: 1.5rem; font-weight: 900; }
  .team-card-stats {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0;
    border-top: 1px solid var(--border2);
  }
  .tc-stat { padding: 0.7rem 0.9rem; border-right: 1px solid var(--border2); text-align: center; }
  .tc-stat:last-child { border-right: none; }
  .tc-stat-val { font-size: 1rem; font-weight: 800; }
  .tc-stat-lbl { font-size: 0.57rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 0.08rem; }
  .wr-bar-wrap { padding: 0 1.2rem 1rem; }
  .wr-bar { height: 4px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; margin-top: 0.4rem; }
  .wr-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #4f46e5, #34d399); }

  /* ─── MAP TAB ────────────────────────────────────────────── */
  .maps-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px,1fr)); gap: 1rem; }
  .map-card {
    border-radius: var(--r-lg); border: 1px solid var(--border);
    background: rgba(17,14,39,0.7); overflow: hidden;
  }
  .map-card-head {
    padding: 1rem 1.2rem; display: flex; align-items: center; gap: 0.8rem;
    border-bottom: 1px solid var(--border2);
  }
  .map-name-big {
    font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary);
  }
  .map-name-raw { font-size: 0.62rem; color: var(--muted); font-family: monospace; }
  .map-matches { margin-left: auto; font-size: 0.65rem; color: var(--muted); }
  .map-card-body { padding: 0.9rem 1.2rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .map-row { display: flex; align-items: center; gap: 0.6rem; font-size: 0.76rem; }
  .map-row-label { width: 80px; color: var(--muted); flex-shrink: 0; }
  .map-vs-bar {
    flex: 1; height: 8px; border-radius: 4px; overflow: hidden;
    background: rgba(245,158,11,0.2); position: relative;
  }
  .map-ct-fill {
    position: absolute; left: 0; top: 0; height: 100%; border-radius: 4px;
    background: linear-gradient(90deg, #38bdf8, #0ea5e9);
  }
  .map-pct-ct { min-width: 36px; text-align: right; color: var(--ct); font-weight: 700; }
  .map-pct-t  { min-width: 36px; color: var(--t); font-weight: 700; }
  .map-divider { font-size: 0.65rem; color: var(--muted); }
  .map-outcome-chips { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .chip {
    font-size: 0.62rem; font-weight: 700; padding: 0.18rem 0.5rem;
    border-radius: 50px; white-space: nowrap;
  }
  .chip-ct { background: rgba(56,189,248,0.1); border: 1px solid rgba(56,189,248,0.2); color: var(--ct); }
  .chip-t  { background: rgba(245,158,11,0.1);  border: 1px solid rgba(245,158,11,0.2);  color: var(--t); }
  .chip-n  { background: rgba(99,102,241,0.1);  border: 1px solid rgba(99,102,241,0.2);  color: #a5b4fc; }

  /* ─── HISTORY TAB ────────────────────────────────────────── */
  .history-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .hist-row {
    display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
    background: rgba(17,14,39,0.6); border: 1px solid var(--border);
    border-radius: var(--r); padding: 0.75rem 1rem;
    cursor: pointer; transition: border-color 0.15s, background 0.15s;
  }
  .hist-row:hover { border-color: rgba(99,102,241,0.3); background: rgba(99,102,241,0.04); }
  .hist-map {
    background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.22);
    border-radius: 6px; padding: 0.15rem 0.5rem;
    font-size: 0.68rem; font-weight: 800; color: #a5b4fc;
    letter-spacing: 0.05em; flex-shrink: 0;
  }
  .hist-teams { flex: 1; display: flex; align-items: center; gap: 0.55rem; min-width: 0; flex-wrap: wrap; }
  .hist-team-logo { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; }
  .hist-tname { font-size: 0.8rem; font-weight: 700; }
  .hist-score-block { font-size: 0.95rem; font-weight: 900; letter-spacing: 0.04em; white-space: nowrap; }
  .hist-score-block .cs { color: var(--ct); }
  .hist-score-block .ts { color: var(--t); }
  .hist-score-block .sp { color: var(--muted); font-weight: 300; margin: 0 0.1rem; }
  .winner-tag {
    font-size: 0.6rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 50px;
    background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.25); color: #6ee7b7;
    white-space: nowrap; flex-shrink: 0;
  }
  .rounds-tag { font-size: 0.65rem; color: var(--muted); flex-shrink: 0; }
  .hist-date  { font-size: 0.63rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }
  .del-btn {
    background: transparent; border: 1px solid rgba(239,68,68,0.2); color: rgba(239,68,68,0.45);
    border-radius: 6px; padding: 0.2rem 0.5rem; cursor: pointer; font-size: 0.68rem;
    transition: all 0.15s; flex-shrink: 0; margin-left: auto;
  }
  .del-btn:hover { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.55); color: #f87171; }

  /* ─── H2H TAB ────────────────────────────────────────────── */
  .h2h-selector {
    display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.2rem;
  }
  .h2h-select {
    flex: 1; min-width: 160px; padding: 0.55rem 1rem;
    background: rgba(17,14,39,0.8); border: 1px solid var(--border);
    border-radius: 9px; color: var(--text); font-family: inherit;
    font-size: 0.82rem; outline: none; transition: border-color 0.15s;
  }
  .h2h-select:focus { border-color: rgba(99,102,241,0.5); }
  .h2h-vs { font-size: 0.75rem; color: var(--muted); font-weight: 700; flex-shrink: 0; }
  .h2h-btn {
    background: linear-gradient(135deg, #4f46e5, #6366f1); color: #fff;
    border: none; border-radius: 9px; padding: 0.55rem 1.4rem;
    font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: opacity 0.15s;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .h2h-btn:hover { opacity: 0.85; }
  .h2h-result-card {
    border-radius: var(--r-lg); border: 1px solid var(--border);
    background: rgba(17,14,39,0.7); overflow: hidden;
  }
  .h2h-scoreline {
    display: flex; align-items: center; justify-content: center; gap: 0;
    border-bottom: 1px solid var(--border2);
  }
  .h2h-side { flex: 1; padding: 1.8rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; }
  .h2h-side.left  { border-right: 1px solid var(--border2); }
  .h2h-tname { font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em; text-align: center; }
  .h2h-middle { padding: 1.8rem 2rem; text-align: center; flex-shrink: 0; }
  .h2h-big-score { font-size: 2.8rem; font-weight: 900; letter-spacing: 0.04em; line-height: 1; }
  .h2h-big-score .ws { color: var(--success); }
  .h2h-big-score .ls { color: var(--danger); }
  .h2h-big-score .ms { color: var(--muted); font-weight: 300; font-size: 2rem; }
  .h2h-sub { font-size: 0.65rem; color: var(--muted); margin-top: 0.3rem; }

  /* ─── Modal ──────────────────────────────────────────────── */
  .modal-bg {
    display: none; position: fixed; inset: 0;
    background: rgba(4,2,14,0.85); backdrop-filter: blur(12px);
    z-index: 500; align-items: center; justify-content: center; padding: 1rem;
  }
  .modal-bg.open { display: flex; }
  .modal-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); width: 760px; max-width: 98vw; max-height: 92vh;
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.7);
    animation: modalIn 0.25s ease;
  }
  @keyframes modalIn { from{opacity:0;transform:scale(0.94) translateY(10px)} to{opacity:1;transform:none} }
  .modal-head {
    padding: 1rem 1.2rem; border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: space-between;
  }
  .modal-title { font-size: 0.9rem; font-weight: 700; color: var(--text); }
  .modal-close-btn {
    background: transparent; border: none; color: var(--muted);
    cursor: pointer; font-size: 1.3rem; padding: 0 0.3rem; border-radius: 4px;
    transition: color 0.15s;
  }
  .modal-close-btn:hover { color: var(--danger); }
  .modal-body { overflow-y: auto; padding: 1.2rem; flex: 1; }
  .modal-table { width: 100%; border-collapse: collapse; font-size: 0.79rem; }
  .modal-table th {
    padding: 0.4rem 0.6rem; text-align: left; font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--border2); white-space: nowrap;
  }
  .modal-table th.r, .modal-table td.r { text-align: right; }
  .modal-table td { padding: 0.45rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.025); vertical-align: middle; }
  .modal-table tr:last-child td { border-bottom: none; }
  .modal-table tbody tr:hover td { background: rgba(99,102,241,0.04); }
  .modal-player { display: flex; align-items: center; gap: 0.5rem; }
  .modal-avatar {
    width: 28px; height: 28px; border-radius: 6px; object-fit: cover;
    border: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.3); flex-shrink: 0;
  }
  .modal-avatar-ph {
    width: 28px; height: 28px; border-radius: 6px; flex-shrink: 0;
    background: rgba(79,70,229,0.1); border: 1px solid rgba(99,102,241,0.15);
    display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: var(--muted);
  }

  /* ─── Confirm dialog ─────────────────────────────────────── */
  .confirm-bg {
    display: none; position: fixed; inset: 0;
    background: rgba(4,2,14,0.88); backdrop-filter: blur(10px);
    z-index: 600; align-items: center; justify-content: center;
  }
  .confirm-bg.open { display: flex; }
  .confirm-box {
    background: var(--surface); border: 1px solid rgba(239,68,68,0.3);
    border-radius: var(--r-lg); padding: 2rem; width: 380px; max-width: 95vw;
    text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    animation: modalIn 0.2s ease;
  }
  .confirm-icon { font-size: 2.5rem; margin-bottom: 0.8rem; opacity: 0.7; }
  .confirm-box h3 { font-size: 1rem; font-weight: 700; color: #f87171; margin-bottom: 0.5rem; }
  .confirm-box p  { font-size: 0.8rem; color: var(--text2); margin-bottom: 1.4rem; line-height: 1.5; }
  .confirm-actions { display: flex; gap: 0.7rem; justify-content: center; }
  .cbtn-danger  { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4); color: #f87171; padding: 0.5rem 1.4rem; border-radius: 7px; cursor: pointer; font-weight: 700; font-size: 0.82rem; transition: all 0.15s; }
  .cbtn-danger:hover { background: rgba(239,68,68,0.25); }
  .cbtn-cancel { background: transparent; border: 1px solid var(--border2); color: var(--text2); padding: 0.5rem 1.4rem; border-radius: 7px; cursor: pointer; font-size: 0.82rem; transition: all 0.15s; }
  .cbtn-cancel:hover { border-color: var(--border); color: var(--text); }

  /* ─── Filter bar ─────────────────────────────────────────── */
  .filter-input {
    padding: 0.42rem 0.85rem; background: rgba(0,0,0,0.25);
    border: 1px solid var(--border2); border-radius: 8px;
    color: var(--text); font-family: inherit; font-size: 0.8rem; outline: none;
    transition: border-color 0.15s; min-width: 160px;
  }
  .filter-input:focus { border-color: rgba(99,102,241,0.45); }
  .filter-input::placeholder { color: var(--muted); }

  /* ─── No data ────────────────────────────────────────────── */
  .no-data { text-align: center; padding: 3rem; color: var(--muted); font-style: italic; font-size: 0.85rem; }

  /* ─── Misc ───────────────────────────────────────────────── */
  @media(max-width:640px) {
    .sb-scores { font-size: 2.8rem; }
    .nav-tab span { display: none; }
    .nav-tab { padding: 0.5rem 0.85rem; }
  }
  </style>
</head>
<body>

<!-- ════ HEADER ════════════════════════════════════════════════════════════ -->
<header class="site-header">
  <a href="/stats" class="header-logo">
    <div class="logo-icon"><i class="fas fa-chart-bar"></i></div>
    <span class="logo-text">Galaxy<span>Stats</span></span>
  </a>
  <div class="header-right">
    <div class="header-update" id="lastUpdate"><i class="fas fa-circle" style="font-size:0.4rem;color:#34d399"></i> —</div>
    <a href="/admin" class="hbtn"><i class="fas fa-shield-alt"></i> Admin</a>
  </div>
</header>

<!-- ════ MAIN ══════════════════════════════════════════════════════════════ -->
<div class="page">

  <!-- Nav tabs -->
  <div class="nav-tabs">
    <button class="nav-tab active" data-tab="match">
      <i class="fas fa-fire tab-icon"></i><span>Current Match</span>
    </button>
    <button class="nav-tab" data-tab="players">
      <i class="fas fa-trophy tab-icon"></i><span>Players</span>
    </button>
    <button class="nav-tab" data-tab="teams">
      <i class="fas fa-users tab-icon"></i><span>Teams</span>
    </button>
    <button class="nav-tab" data-tab="history">
      <i class="fas fa-history tab-icon"></i><span>History</span>
    </button>
    <button class="nav-tab" data-tab="maps">
      <i class="fas fa-map tab-icon"></i><span>Maps</span>
    </button>
    <button class="nav-tab" data-tab="h2h">
      <i class="fas fa-exchange-alt tab-icon"></i><span>H2H</span>
    </button>
  </div>

  <!-- ══ MATCH ═══════════════════════════════════════════════════════════ -->
  <div class="tab-panel active" id="tab-match">
    <div id="match-no-data" class="match-no-data" style="display:none">
      <div class="ndi"><i class="fas fa-satellite-dish"></i></div>
      <p>Waiting for live GSI data...</p>
      <span style="font-size:0.7rem;color:var(--muted)">Make sure your CS2 GSI config is active</span>
    </div>
    <div id="match-content">
      <!-- Score banner -->
      <div class="score-banner" id="score-banner">
        <div class="sb-team ct-side" id="sb-ct">
          <img id="sb-ct-logo" class="sb-logo" src="" style="display:none">
          <div class="sb-logo-ph" id="sb-ct-ph"><i class="fas fa-shield-alt"></i></div>
          <div class="sb-team-name" id="sb-ct-name">CT</div>
          <div class="sb-team-side ct">Counter-Terrorist</div>
        </div>
        <div class="sb-center">
          <div class="live-badge"><span class="live-dot"></span> LIVE</div>
          <div class="sb-scores">
            <span class="ct-s" id="sb-score-ct">0</span>
            <span class="sep">:</span>
            <span class="t-s" id="sb-score-t">0</span>
          </div>
          <div class="sb-map" id="sb-map">—</div>
          <div class="sb-rounds" id="sb-rounds">0 rounds played</div>
        </div>
        <div class="sb-team t-side" id="sb-t">
          <img id="sb-t-logo" class="sb-logo" src="" style="display:none">
          <div class="sb-logo-ph" id="sb-t-ph"><i class="fas fa-bomb"></i></div>
          <div class="sb-team-name" id="sb-t-name">T</div>
          <div class="sb-team-side t">Terrorist</div>
        </div>
      </div>

      <!-- Player sides -->
      <div class="match-sides">
        <!-- CT -->
        <div class="match-side-card ct-card">
          <div class="side-header">
            <div class="side-label ct"><i class="fas fa-shield-alt"></i> CT Side</div>
            <div class="live-badge"><span class="live-dot"></span> LIVE</div>
          </div>
          <div class="player-row-ph">
            <span>Player</span>
            <span>K</span><span>D</span><span>A</span>
            <span>ADR</span><span>K/D</span>
            <span>KAST</span><span>Rating</span>
          </div>
          <div class="player-rows" id="rows-ct"></div>
        </div>
        <!-- T -->
        <div class="match-side-card t-card">
          <div class="side-header">
            <div class="side-label t"><i class="fas fa-bomb"></i> T Side</div>
            <div class="live-badge"><span class="live-dot"></span> LIVE</div>
          </div>
          <div class="player-row-ph">
            <span>Player</span>
            <span>K</span><span>D</span><span>A</span>
            <span>ADR</span><span>K/D</span>
            <span>KAST</span><span>Rating</span>
          </div>
          <div class="player-rows" id="rows-t"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ PLAYERS ════════════════════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-players">
    <!-- Podium -->
    <div class="podium-row" id="podium-row"></div>
    <!-- Table -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-list-ol"></i> Full Leaderboard</div>
        <input class="filter-input" id="filter-players" placeholder="Search player...">
      </div>
      <div style="overflow-x:auto">
        <table class="lb-table" id="lb-table">
          <thead><tr>
            <th style="width:32px">#</th>
            <th>Player</th>
            <th class="r" data-sort="matchesPlayed">M</th>
            <th class="r" data-sort="kills">K</th>
            <th class="r" data-sort="deaths">D</th>
            <th class="r" data-sort="assists">A</th>
            <th class="r" data-sort="adr">ADR</th>
            <th class="r" data-sort="kd">K/D</th>
            <th class="r" data-sort="kast">KAST%</th>
            <th class="r" data-sort="hsRate">HS%</th>
            <th class="r" data-sort="mvps">MVP</th>
            <th class="r" data-sort="firstKills" title="Entry Kills">EK</th>
            <th class="r" data-sort="fiveKills" title="Aces">ACE</th>
            <th class="r" data-sort="kpr">KPR</th>
            <th class="r" data-sort="galaxyRating">Rating</th>
          </tr></thead>
          <tbody id="lb-tbody"></tbody>
        </table>
      </div>
      <div class="no-data" id="no-players" style="display:none">No stats yet. Play some matches!</div>
    </div>
  </div>

  <!-- ══ TEAMS ══════════════════════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-teams">
    <div class="teams-grid" id="teams-grid">
      <div class="no-data" style="grid-column:1/-1">No team stats yet.</div>
    </div>
  </div>

  <!-- ══ HISTORY ════════════════════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-history">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-history"></i> Match History</div>
        <input class="filter-input" id="filter-history" placeholder="Map or team...">
      </div>
      <div style="padding: 1rem">
        <div class="history-list" id="history-list">
          <div class="no-data">No matches yet.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ MAPS ═══════════════════════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-maps">
    <div class="maps-grid" id="maps-grid">
      <div class="no-data" style="grid-column:1/-1">No map stats yet.</div>
    </div>
  </div>

  <!-- ══ H2H ════════════════════════════════════════════════════════════ -->
  <div class="tab-panel" id="tab-h2h">
    <div class="card" style="padding:1.4rem">
      <div class="h2h-selector">
        <select class="h2h-select" id="h2h-t1"><option value="">— Team 1 —</option></select>
        <span class="h2h-vs">VS</span>
        <select class="h2h-select" id="h2h-t2"><option value="">— Team 2 —</option></select>
        <button class="h2h-btn" id="h2h-go"><i class="fas fa-search"></i> Compare</button>
      </div>
      <div id="h2h-result"></div>
    </div>
  </div>

</div>

<!-- ════ MATCH DETAIL MODAL ════════════════════════════════════════════════ -->
<div class="modal-bg" id="modal-bg">
  <div class="modal-box">
    <div class="modal-head">
      <div class="modal-title" id="modal-title">Match Details</div>
      <button class="modal-close-btn" id="modal-close">&times;</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>
</div>

<!-- ════ CONFIRM DELETE ═════════════════════════════════════════════════════ -->
<div class="confirm-bg" id="confirm-bg">
  <div class="confirm-box">
    <div class="confirm-icon">🗑️</div>
    <h3>Delete this match?</h3>
    <p>The match will be permanently removed and all global statistics will be recalculated.</p>
    <div class="confirm-actions">
      <button class="cbtn-danger"  id="confirm-ok">Delete</button>
      <button class="cbtn-cancel"  id="confirm-cancel">Cancel</button>
    </div>
  </div>
</div>

<script>
// ─── Utils ─────────────────────────────────────────────────────────────────
function rc(r) {
  if (r >= 1.15) return '#34d399';
  if (r >= 1.0)  return '#a3e635';
  if (r >= 0.85) return '#fbbf24';
  return '#f87171';
}
function ratingBar(val, max=2) {
  const pct = Math.min(100, (val / max) * 100);
  const c = rc(val);
  return `<div class="lb-rating">
    <div class="lb-rbar"><div class="lb-rfill" style="width:${pct}%;background:${c}"></div></div>
    <div class="lb-rval" style="color:${c}">${val.toFixed(2)}</div>
  </div>`;
}
function miniRating(val, max=2) {
  const pct = Math.min(100, (val / max) * 100);
  const c = rc(val);
  return `<div class="mini-rating">
    <div class="mini-bar"><div class="mini-fill" style="width:${pct}%;background:${c}"></div></div>
    <div class="mini-val" style="color:${c}">${val.toFixed(2)}</div>
  </div>`;
}
function ava(photo, name, cls='lb-avatar', phCls='lb-avatar-ph') {
  return photo
    ? `<img class="${cls}" src="${photo}" alt="${name||''}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
       <div class="${phCls}" style="display:none"><i class="fas fa-user"></i></div>`
    : `<div class="${phCls}"><i class="fas fa-user"></i></div>`;
}
function tlogoHtml(logo, name, cls='hist-team-logo') {
  return logo ? `<img class="${cls}" src="${logo}" alt="${name||''}" onerror="this.style.display='none'">` : '';
}
function fmt(n) { return n !== undefined && n !== null ? n : '—'; }
function hs(kills, headshots) {
  return kills ? Math.round((headshots / kills) * 100) + '%' : '0%';
}
function ago(iso) {
  if (!iso) return '';
  const d = Date.now() - new Date(iso).getTime();
  if (d < 60000) return 'just now';
  if (d < 3600000) return Math.floor(d/60000) + 'm ago';
  if (d < 86400000) return Math.floor(d/3600000) + 'h ago';
  return new Date(iso).toLocaleDateString();
}
function plink(steamId) { return `/stats/player?id=${encodeURIComponent(steamId)}`; }
function tlink(name)    { return `/stats/team?name=${encodeURIComponent(name)}`; }

