// ─── Sort state ────────────────────────────────────────────────────────────
let sortCol = 'galaxyRating', sortDir = -1;
let _globalPlayersData = [];

function applySortHeaders() {
  document.querySelectorAll('#lb-table thead th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      sortDir = sortCol === col ? -sortDir : -1;
      sortCol = col;
      document.querySelectorAll('#lb-table thead th').forEach(t => t.classList.remove('sort-asc','sort-desc'));
      th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
      const filtered = applyFilter(_globalPlayersData);
      renderLeaderboard(filtered);
    });
  });
}

function applyFilter(data) {
  const q = (document.getElementById('filter-players').value || '').toLowerCase();
  return q ? data.filter(p => (p.name||'').toLowerCase().includes(q) || p.steamId.includes(q)) : data;
}

// ─── MATCH ─────────────────────────────────────────────────────────────────
function renderMatchTab(data) {
  const noData = document.getElementById('match-no-data');
  const content = document.getElementById('match-content');
  if (!data) { noData.style.display='flex'; content.style.display='none'; return; }
  noData.style.display = 'none';
  content.style.display = '';

  // Scoreline
  const ct = data.teamCT || {};
  const t  = data.teamT  || {};
  const ctLogoEl = document.getElementById('sb-ct-logo');
  const tLogoEl  = document.getElementById('sb-t-logo');
  const ctPhEl   = document.getElementById('sb-ct-ph');
  const tPhEl    = document.getElementById('sb-t-ph');
  if (ct.logo) { ctLogoEl.src=ct.logo; ctLogoEl.style.display=''; ctPhEl.style.display='none'; }
  if (t.logo)  { tLogoEl.src=t.logo;   tLogoEl.style.display='';  tPhEl.style.display='none'; }
  document.getElementById('sb-ct-name').textContent  = ct.name || 'CT';
  document.getElementById('sb-t-name').textContent   = t.name  || 'T';
  document.getElementById('sb-score-ct').textContent = ct.score ?? 0;
  document.getElementById('sb-score-t').textContent  = t.score  ?? 0;
  document.getElementById('sb-map').textContent      = (data.mapName||'—').replace('de_','').toUpperCase();
  document.getElementById('sb-rounds').textContent   = (data.roundCount||0) + ' rounds played';

  const players = Object.values(data.players||{});
  const ctPlayers = players.filter(p => p._team==='CT').sort((a,b) => b.kills-a.kills);
  const tPlayers  = players.filter(p => p._team==='T').sort((a,b) => b.kills-a.kills);
  const half = Math.ceil(players.length / 2);
  const ctFinal = ctPlayers.length ? ctPlayers : [...players].sort((a,b)=>b.kills-a.kills).slice(0,half);
  const tFinal  = tPlayers.length  ? tPlayers  : [...players].sort((a,b)=>b.kills-a.kills).slice(half);

  document.getElementById('rows-ct').innerHTML = ctFinal.map(p => playerMatchRow(p)).join('') || '<div class="no-data" style="padding:1rem">No data</div>';
  document.getElementById('rows-t').innerHTML  = tFinal.map(p  => playerMatchRow(p)).join('') || '<div class="no-data" style="padding:1rem">No data</div>';
}

function playerMatchRow(p) {
  const nameLink = p.steamId
    ? `<a class="pr-name" href="${plink(p.steamId)}">${p.name||p.steamId||'—'}</a>`
    : `<span class="pr-name">${p.name||'—'}</span>`;
  const kdC = (p.kd||0)>=1 ? 'good' : 'bad';
  return `<div class="player-row">
    ${ava(p.photo, p.name, 'pr-avatar', 'pr-avatar-ph')}
    <div class="pr-info">${nameLink}<div class="pr-tag">K/D ${p.kd||0}</div></div>
    <div class="pr-num hi">${fmt(p.kills)}</div>
    <div class="pr-num">${fmt(p.deaths)}</div>
    <div class="pr-num">${fmt(p.assists)}</div>
    <div class="pr-num">${fmt(p.adr)}</div>
    <div class="pr-num ${kdC}">${fmt(p.kd)}</div>
    <div class="pr-num">${fmt(p.kast)}%</div>
    ${miniRating(p.galaxyRating||0)}
  </div>`;
}

// ─── LEADERBOARD ───────────────────────────────────────────────────────────
function renderPodium(players) {
  const top3 = players.slice(0,3);
