  const rankClass = ['rank-1','rank-2','rank-3'];
  const rankLabel = ['🥇','🥈','🥉'];
  document.getElementById('podium-row').innerHTML = top3.map((p, i) => {
    const c = rc(p.galaxyRating);
    return `<div class="podium-card ${rankClass[i]}">
      ${i===0 ? '<div class="crown">👑</div>' : ''}
      <div class="podium-rank">${i+1}</div>
      ${ava(p.photo, p.name, 'podium-avatar', 'podium-avatar-ph')}
      <a class="podium-name" href="${plink(p.steamId)}">${p.name||p.steamId||'—'}</a>
