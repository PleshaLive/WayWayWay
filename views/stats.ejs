// ─── HISTORY ───────────────────────────────────────────────────────────────
let _allHistory = [];

function renderHistory(data) {
  const list = document.getElementById('history-list');
  if (!data.length) { list.innerHTML='<div class="no-data">No match history yet.</div>'; return; }
  list.innerHTML = data.map(m => {
    const ctN = m.teamCT?.name||'CT';
    const tN  = m.teamT?.name||'T';
    return `<div class="hist-row" data-id="${m.id}">
      <div class="hist-map">${(m.mapName||'?').replace('de_','').toUpperCase()}</div>
      <div class="hist-teams">
        ${tlogoHtml(m.teamCT?.logo, ctN)}
        <span class="hist-tname"><a href="${tlink(ctN)}" style="color:inherit;text-decoration:none" onmouseover="this.style.color='#a5b4fc'" onmouseout="this.style.color=''">${ctN}</a></span>
        <div class="hist-score-block"><span class="cs">${m.teamCT?.score??0}</span><span class="sp">:</span><span class="ts">${m.teamT?.score??0}</span></div>
        <span class="hist-tname"><a href="${tlink(tN)}" style="color:inherit;text-decoration:none" onmouseover="this.style.color='#a5b4fc'" onmouseout="this.style.color=''">${tN}</a></span>
        ${tlogoHtml(m.teamT?.logo, tN)}
      </div>
      ${m.winner ? `<span class="winner-tag">🏆 ${m.winner}</span>` : ''}
      <span class="rounds-tag">${m.roundCount||0}r</span>
      <span class="hist-date">${ago(m.finishedAt||m.startedAt)}</span>
      <button class="del-btn" title="Delete" onclick="event.stopPropagation();delConfirm('${m.id}')"><i class="fas fa-trash"></i></button>
    </div>`;
  }).join('');
  list.querySelectorAll('.hist-row').forEach(el => {
    el.addEventListener('click', () => openMatchDetail(el.dataset.id));
  });
}

document.getElementById('filter-history').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  renderHistory(_allHistory.filter(m =>
    (m.mapName||'').toLowerCase().includes(q) ||
    (m.teamCT?.name||'').toLowerCase().includes(q) ||
    (m.teamT?.name||'').toLowerCase().includes(q)
  ));
});

function openMatchDetail(id) {
  const m = _allHistory.find(x => x.id === id);
  if (!m) return;
  const players = Object.values(m.players||{}).sort((a,b) => b.galaxyRating - a.galaxyRating);
  const ro = m.roundOutcomes || {};
  const roChips = [
    ro.ct_win_defuse      && `<div class="chip chip-ct">💣 Defuse: ${ro.ct_win_defuse}</div>`,
    ro.ct_win_elimination && `<div class="chip chip-ct">🔫 CT Elim: ${ro.ct_win_elimination}</div>`,
    ro.ct_win_time        && `<div class="chip chip-n">⏱ CT Time: ${ro.ct_win_time}</div>`,
    ro.t_win_bomb         && `<div class="chip chip-t">💥 Bomb: ${ro.t_win_bomb}</div>`,
    ro.t_win_elimination  && `<div class="chip chip-t">🔫 T Elim: ${ro.t_win_elimination}</div>`,
  ].filter(Boolean).join('');
  document.getElementById('modal-title').textContent =
    `${(m.mapName||'').replace('de_','').toUpperCase()} — ${m.teamCT?.name||'CT'} ${m.teamCT?.score??0} : ${m.teamT?.score??0} ${m.teamT?.name||'T'}`;
  document.getElementById('modal-body').innerHTML = `
    <div style="font-size:0.7rem;color:var(--muted);margin-bottom:0.6rem">
      <i class="fas fa-calendar"></i> ${new Date(m.startedAt||m.finishedAt).toLocaleString()}
      &nbsp;·&nbsp; ${m.roundCount||0} rounds
      ${m.winner ? `&nbsp;·&nbsp; <span style="color:#34d399">🏆 ${m.winner}</span>` : ''}
    </div>
    ${roChips ? `<div style="display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:1rem">${roChips}</div>` : ''}
    <table class="modal-table">
      <thead><tr>
        <th>Player</th><th class="r">K</th><th class="r">D</th><th class="r">A</th>
        <th class="r">ADR</th><th class="r">K/D</th><th class="r">KAST%</th>
        <th class="r">HS%</th><th class="r">MVP</th><th class="r">MK</th><th class="r">Rating</th>
      </tr></thead>
      <tbody>${players.map(p => {
        const mkStr = p.fiveKills ? `<span style="color:#34d399">${p.fiveKills}×5K</span>` :
                      p.fourKills ? `<span style="color:#a78bfa">${p.fourKills}×4K</span>` :
                      p.threeKills ? `<span style="color:#60a5fa">${p.threeKills}×3K</span>` : '—';
        return `<tr>
          <td><div class="modal-player">
            ${ava(p.photo, p.name, 'modal-avatar', 'modal-avatar-ph')}
            <a href="${plink(p.steamId)}" style="font-size:0.82rem;font-weight:600;color:var(--text);text-decoration:none" onmouseover="this.style.color='#a5b4fc'" onmouseout="this.style.color=''">${p.name||p.steamId||'—'}</a>
          </div></td>
          <td class="r" style="font-weight:700;color:var(--text)">${p.kills}</td>
          <td class="r">${p.deaths}</td><td class="r">${p.assists}</td>
          <td class="r">${p.adr}</td>
          <td class="r" style="color:${p.kd>=1?'#34d399':'#f87171'}">${p.kd}</td>
          <td class="r">${p.kast}%</td>
          <td class="r">${p.hsRate!==undefined ? p.hsRate+'%' : hs(p.kills,p.headshots)}</td>
          <td class="r" style="color:#fbbf24">${p.mvps||0}</td>
          <td class="r">${mkStr}</td>
          <td class="r">${ratingBar(p.galaxyRating)}</td>
        </tr>`;
      }).join('')}</tbody>
    </table>`;
  document.getElementById('modal-bg').classList.add('open');
}

// ─── H2H ───────────────────────────────────────────────────────────────────
function populateH2H(names) {
  const opts = names.map(n => `<option value="${n}">${n}</option>`).join('');
  document.getElementById('h2h-t1').innerHTML = '<option value="">— Team 1 —</option>' + opts;
  document.getElementById('h2h-t2').innerHTML = '<option value="">— Team 2 —</option>' + opts;
}

document.getElementById('h2h-go').addEventListener('click', () => {
  const t1 = document.getElementById('h2h-t1').value;
  const t2 = document.getElementById('h2h-t2').value;
  const el = document.getElementById('h2h-result');
  if (!t1||!t2||t1===t2) { el.innerHTML='<div class="no-data">Select two different teams.</div>'; return; }
  const matches = _allHistory.filter(m => {
    const names = [(m.teamCT?.name||'').toLowerCase(),(m.teamT?.name||'').toLowerCase()];
    return names.includes(t1.toLowerCase()) && names.includes(t2.toLowerCase());
  });
  if (!matches.length) { el.innerHTML=`<div class="no-data">No matches found between <b>${t1}</b> and <b>${t2}</b>.</div>`; return; }
  let w1=0,w2=0,d=0;
  matches.forEach(m => {
    if(!m.winner) d++;
    else if(m.winner.toLowerCase()===t1.toLowerCase()) w1++;
    else if(m.winner.toLowerCase()===t2.toLowerCase()) w2++;
    else d++;
  });
  el.innerHTML = `<div class="h2h-result-card">
    <div class="h2h-scoreline">
      <div class="h2h-side left">
        <div class="h2h-tname">${t1}</div>
        <div style="font-size:0.65rem;color:var(--muted)">${w1} win${w1!==1?'s':''}</div>
      </div>
      <div class="h2h-middle">
        <div class="h2h-big-score">
          <span class="ws">${w1}</span><span class="ms"> — </span><span class="ls">${w2}</span>
        </div>
        <div class="h2h-sub">${matches.length} match${matches.length!==1?'es':''} · ${d} draw${d!==1?'s':''}</div>
      </div>
      <div class="h2h-side">
        <div class="h2h-tname">${t2}</div>
        <div style="font-size:0.65rem;color:var(--muted)">${w2} win${w2!==1?'s':''}</div>
      </div>
    </div>
    <div style="padding:1rem">
      <div class="history-list">${matches.map(m => {
        const ctN = m.teamCT?.name||'CT';
        const tN  = m.teamT?.name||'T';
        return `<div class="hist-row" data-id="${m.id}" style="cursor:pointer">
          <div class="hist-map">${(m.mapName||'?').replace('de_','').toUpperCase()}</div>
          <div class="hist-teams">
            <span class="hist-tname">${ctN}</span>
            <div class="hist-score-block"><span class="cs">${m.teamCT?.score??0}</span><span class="sp">:</span><span class="ts">${m.teamT?.score??0}</span></div>
            <span class="hist-tname">${tN}</span>
          </div>
          ${m.winner?`<span class="winner-tag">🏆 ${m.winner}</span>`:''}
          <span class="hist-date">${ago(m.finishedAt||m.startedAt)}</span>
        </div>`;
      }).join('')}</div>
    </div>
  </div>`;
  el.querySelectorAll('.hist-row').forEach(r => r.addEventListener('click', () => openMatchDetail(r.dataset.id)));
});

// ─── Delete match ──────────────────────────────────────────────────────────
let _delId = null;
function delConfirm(id) {
  _delId = id;
  document.getElementById('confirm-bg').classList.add('open');
}
document.getElementById('confirm-ok').addEventListener('click', async () => {
  if (!_delId) return;
  document.getElementById('confirm-bg').classList.remove('open');
  try {
    const r = await fetch('/api/stats/history/' + _delId, { method: 'DELETE' });
    if (!r.ok) throw new Error();
    _delId = null;
    await fetchAll();
  } catch { alert('Failed to delete match.'); }
});
document.getElementById('confirm-cancel').addEventListener('click', () => {
  _delId = null; document.getElementById('confirm-bg').classList.remove('open');
});
document.getElementById('confirm-bg').addEventListener('click', e => {
  if (e.target===document.getElementById('confirm-bg')) { _delId=null; document.getElementById('confirm-bg').classList.remove('open'); }
});

// ─── Fetch all data ─────────────────────────────────────────────────────────
async function fetchAll() {
  try {
    const [mRes, pRes, tRes, hRes, mapRes] = await Promise.all([
      fetch('/api/stats/match'),
      fetch('/api/stats/players'),
      fetch('/api/stats/teams'),
      fetch('/api/stats/history?limit=50'),
      fetch('/api/stats/maps'),
    ]);
    const [mData, pData, tData, hData, mapData] = await Promise.all([
      mRes.json(), pRes.json(), tRes.json(), hRes.json(), mapRes.json(),
    ]);

    renderMatchTab(mData.status === 'live' ? mData.data : null);

    _globalPlayersData = pData || [];
    renderPodium(_globalPlayersData.slice(0,3));
    renderLeaderboard(_globalPlayersData);
    applySortHeaders();

    renderTeams(tData || []);

    _allHistory = hData.data || [];
    renderHistory(_allHistory);
    const teamNames = [...new Set([
      ..._allHistory.map(m => m.teamCT?.name).filter(Boolean),
      ..._allHistory.map(m => m.teamT?.name).filter(Boolean),
    ])].sort();
    populateH2H(teamNames);

    renderMaps(mapData || []);

    document.getElementById('lastUpdate').innerHTML =
      `<i class="fas fa-circle" style="font-size:0.4rem;color:#34d399"></i> ${new Date().toLocaleTimeString()}`;
  } catch(e) { console.error('Stats fetch error:', e); }
}

fetchAll();
setInterval(() => {
  fetch('/api/stats/match').then(r=>r.json()).then(d => {
    renderMatchTab(d.status==='live' ? d.data : null);
    document.getElementById('lastUpdate').innerHTML =
      `<i class="fas fa-circle" style="font-size:0.4rem;color:#34d399"></i> ${new Date().toLocaleTimeString()}`;
  }).catch(()=>{});
}, 3000);
setInterval(fetchAll, 15000);
</script>
</body>
</html>
