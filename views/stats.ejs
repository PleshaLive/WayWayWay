        </div>
      </div></td>
      <td class="r"><span class="lb-val">${p.matchesPlayed}</span></td>
      <td class="r"><span class="lb-val acc">${p.kills}</span></td>
      <td class="r"><span class="lb-val">${p.deaths}</span></td>
      <td class="r"><span class="lb-val">${p.assists}</span></td>
      <td class="r"><span class="lb-val">${p.adr}</span></td>
      <td class="r"><span class="lb-val ${kdC}">${p.kd}</span></td>
      <td class="r"><span class="lb-val">${p.kast}%</span></td>
      <td class="r"><span class="lb-val">${p.hsRate}%</span></td>
      <td class="r"><span class="lb-val" style="color:#fbbf24">${p.mvps||0}</span></td>
      <td class="r"><span class="lb-val">${p.firstKills||0}</span></td>
      <td class="r"><span class="lb-val" style="color:#34d399">${p.fiveKills||0}</span></td>
