<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galaxy Stats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
  <style>
  :root {
    --bg:        #0E0A1C;
    --surface:   #161228;
    --surface2:  #1e1836;
    --border:    rgba(99,102,241,0.14);
    --border2:   rgba(255,255,255,0.06);
    --text:      #e0e7ff;
    --text2:     #a0aec0;
    --muted:     #5a667a;
    --primary:   #6366f1;
    --primary2:  #4f46e5;
    --success:   #22c55e;
    --warning:   #f59e0b;
    --danger:    #ef4444;
    --gold:      #fbbf24;
    --silver:    #94a3b8;
    --bronze:    #b45309;
    --r:         8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    background-image:
      radial-gradient(ellipse at 10% 0%,   rgba(79,70,229,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 90% 100%, rgba(122,100,185,0.04) 0%, transparent 50%);
  }

  /* ── Header ── */
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(14,10,28,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0.65rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .header-brand { display: flex; align-items: center; gap: 0.8rem; }
  .header-brand h1 { font-size: 1.05rem; font-weight: 700; color: var(--primary); letter-spacing: 0.02em; }
  .header-nav { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.38rem 0.9rem; font-size: 0.76rem; font-weight: 600;
    border-radius: 7px; border: 1px solid transparent;
    cursor: pointer; text-decoration: none; transition: all 0.15s;
    letter-spacing: 0.04em; white-space: nowrap;
  }
  .btn-ghost { background: transparent; border-color: rgba(99,102,241,0.3); color: #9b8fd0; }
  .btn-ghost:hover { background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.55); color: var(--primary); }
  .btn-primary { background: linear-gradient(135deg,#4f46e5,#6366f1); color: #fff; border-color: transparent; }
  .btn-primary:hover { background: linear-gradient(135deg,#5b52ef,#818cf8); }

  /* ── Layout ── */
  .container { max-width: 1600px; margin: 0 auto; padding: 1.2rem 1.4rem; }

  /* ── Tabs ── */
  .tabs-bar {
    display: flex; gap: 0; margin-bottom: 1.4rem;
    background: rgba(34,28,59,0.5);
    border: 1px solid var(--border);
    border-radius: 9px; overflow: hidden;
  }
  .tab-btn {
    flex: 1; padding: 0.7rem 0.5rem; font-size: 0.77rem; font-weight: 600;
    background: transparent; border: none; border-right: 1px solid var(--border);
    color: var(--text2); cursor: pointer; transition: all 0.18s;
    letter-spacing: 0.04em; text-transform: uppercase; display: flex;
    align-items: center; justify-content: center; gap: 0.35rem;
  }
  .tab-btn:last-child { border-right: none; }
  .tab-btn:hover { background: rgba(99,102,241,0.08); color: var(--text); }
  .tab-btn.active { background: rgba(79,70,229,0.2); color: var(--primary); border-bottom: 2px solid var(--primary); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── Card ── */
  .card {
    background: rgba(22,18,40,0.7);
    border: 1px solid var(--border);
    border-radius: var(--r);
    backdrop-filter: blur(10px);
  }
  .card-header {
    padding: 0.8rem 1rem; border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap;
  }
  .card-title { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--primary); display: flex; align-items: center; gap: 0.4rem; }
  .card-body { padding: 0.8rem 1rem; }

  /* ── Live badge ── */
  .live-badge {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em;
    padding: 0.15rem 0.55rem; border-radius: 50px;
    background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.35); color: #f87171;
    animation: pulse-border 1.5s infinite;
  }
  .live-dot { width: 6px; height: 6px; border-radius: 50%; background: #ef4444; animation: pulse-dot 1.5s infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.3} }
  @keyframes pulse-border { 0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0.25)} 50%{box-shadow:0 0 0 4px rgba(239,68,68,0)} }

  /* ── Match scoreboard ── */
  .match-header {
    display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 1rem;
    background: rgba(0,0,0,0.2); border-radius: 9px; overflow: hidden; border: 1px solid var(--border);
  }
  .match-team {
    flex: 1; padding: 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    min-width: 0;
  }
  .match-team.ct { background: rgba(14,165,233,0.05); }
  .match-team.t  { background: rgba(245,158,11,0.05); }
  .match-team-logo { width: 56px; height: 56px; object-fit: contain; }
  .match-team-name { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; text-align: center; }
  .match-team-side { font-size: 0.65rem; color: var(--text2); letter-spacing: 0.08em; }
  .match-score-block { display: flex; flex-direction: column; align-items: center; padding: 0 1.4rem; flex-shrink: 0; }
  .match-score { font-size: 2.6rem; font-weight: 900; letter-spacing: -0.02em; line-height: 1; }
  .match-score .sep { color: var(--muted); margin: 0 0.2rem; font-weight: 300; }
  .match-map { font-size: 0.7rem; color: var(--text2); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.25rem; }
  .match-rounds { font-size: 0.68rem; color: var(--muted); }

  /* ── Stats table ── */
  .stats-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
  .stats-table th {
    padding: 0.45rem 0.6rem; text-align: left;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); border-bottom: 1px solid var(--border2); white-space: nowrap; cursor: pointer;
  }
  .stats-table th:hover { color: var(--text2); }
  .stats-table th.sort-asc::after  { content: ' ↑'; color: var(--primary); }
  .stats-table th.sort-desc::after { content: ' ↓'; color: var(--primary); }
  .stats-table td { padding: 0.42rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; }
  .stats-table tr:last-child td { border-bottom: none; }
  .stats-table tr:hover td { background: rgba(99,102,241,0.05); }
  .stats-table th.r, .stats-table td.r { text-align: right; }
  .stats-table th.c, .stats-table td.c { text-align: center; }

  /* player cell */
  .player-cell { display: flex; align-items: center; gap: 0.5rem; min-width: 0; }
  .player-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    object-fit: cover; border: 1px solid rgba(255,255,255,0.1); flex-shrink: 0;
    background: rgba(0,0,0,0.3);
  }
  .player-avatar-ph {
    width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
    background: rgba(79,70,229,0.15); border: 1px solid rgba(99,102,241,0.2);
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 0.7rem;
  }
  .player-name-text { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .player-team-tag { font-size: 0.65rem; color: var(--muted); }

  /* rating bar */
  .rating-bar-wrap { display: flex; align-items: center; gap: 0.5rem; min-width: 80px; }
  .rating-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
  .rating-bar-fill { height: 100%; border-radius: 2px; transition: width 0.4s; }
  .rating-val { font-size: 0.78rem; font-weight: 700; min-width: 36px; text-align: right; }

  .val-good  { color: #4ade80; }
  .val-ok    { color: #fbbf24; }
  .val-bad   { color: #f87171; }
  .val-hi    { color: var(--primary); font-weight: 700; }

  /* rank medal */
  .rank-1 { color: var(--gold); font-weight: 800; }
  .rank-2 { color: var(--silver); }
  .rank-3 { color: var(--bronze); }

  /* team card in grid */
  .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 0.8rem; }
  .team-stat-card {
    background: rgba(22,18,40,0.7); border: 1px solid var(--border);
    border-radius: var(--r); padding: 0.9rem; display: flex; flex-direction: column; gap: 0.5rem;
    transition: border-color 0.2s;
  }
  .team-stat-card:hover { border-color: rgba(99,102,241,0.3); }
  .team-stat-card-header { display: flex; align-items: center; gap: 0.7rem; }
  .team-logo-sm { width: 36px; height: 36px; object-fit: contain; }
  .team-logo-ph { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 1rem; }
  .team-stat-name { font-weight: 700; font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .team-stat-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.76rem; }
  .team-stat-label { color: var(--text2); }
  .team-stat-value { font-weight: 600; }
  .winrate-bar { height: 5px; border-radius: 3px; background: rgba(255,255,255,0.07); overflow: hidden; }
  .winrate-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #4f46e5, #22c55e); }

  /* history list */
  .history-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .history-item {
    background: rgba(22,18,40,0.7); border: 1px solid var(--border);
    border-radius: var(--r); padding: 0.65rem 0.9rem;
    display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;
    cursor: pointer; transition: border-color 0.15s;
  }
  .history-item:hover { border-color: rgba(99,102,241,0.35); }
  .history-map-badge {
    background: rgba(99,102,241,0.1); border: 1px solid var(--border);
    border-radius: 5px; padding: 0.15rem 0.5rem; font-size: 0.68rem;
    font-weight: 700; color: var(--primary); letter-spacing: 0.06em; flex-shrink: 0;
  }
  .history-teams { flex: 1; display: flex; align-items: center; gap: 0.5rem; min-width: 0; font-size: 0.82rem; font-weight: 600; }
  .history-score { font-weight: 800; font-size: 0.9rem; letter-spacing: 0.04em; }
  .history-score .ct-score { color: #38bdf8; }
  .history-score .t-score  { color: #fbbf24; }
  .history-date { font-size: 0.68rem; color: var(--muted); white-space: nowrap; }
  .winner-tag { font-size: 0.62rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 4px;
                background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
  .rounds-tag { font-size: 0.65rem; color: var(--muted); }

  /* match detail modal */
  .modal-bg {
    display: none; position: fixed; inset: 0; background: rgba(5,3,12,0.82);
    backdrop-filter: blur(8px); z-index: 999; align-items: center; justify-content: center; padding: 1rem;
  }
  .modal-bg.open { display: flex; }
  .modal-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; width: 700px; max-width: 98vw; max-height: 90vh;
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.6);
    animation: fadeIn 0.25s ease;
  }
  @keyframes fadeIn { from{opacity:0;transform:scale(0.96)} to{opacity:1;transform:scale(1)} }
  .modal-header {
    padding: 0.9rem 1.1rem; border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; justify-content: space-between;
  }
  .modal-title { font-size: 0.9rem; font-weight: 700; color: var(--primary); }
  .modal-close { background: transparent; border: none; color: var(--text2); cursor: pointer; font-size: 1.2rem; padding: 0.2rem 0.4rem; border-radius: 5px; }
  .modal-close:hover { color: var(--danger); }
  .modal-body { overflow-y: auto; padding: 1rem; flex: 1; }

  /* h2h */
  .h2h-search { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .h2h-select {
    flex: 1; min-width: 160px; padding: 0.5rem 0.8rem;
    background: rgba(0,0,0,0.25); border: 1px solid var(--border2);
    border-radius: 7px; color: var(--text); font-family: inherit; font-size: 0.85rem; outline: none;
  }
  .h2h-select:focus { border-color: rgba(99,102,241,0.5); }
  .h2h-result { margin-top: 0.8rem; }
  .h2h-scoreline {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    padding: 1.2rem; background: rgba(0,0,0,0.2); border-radius: 9px;
    border: 1px solid var(--border); margin-bottom: 0.8rem;
  }
  .h2h-team-name { font-size: 1.1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .h2h-scores { font-size: 2rem; font-weight: 900; letter-spacing: 0.04em; }
  .h2h-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; text-align: center; margin-top: 0.15rem; }

  /* no-data */
  .no-data { text-align: center; padding: 2.5rem; color: var(--muted); font-style: italic; font-size: 0.85rem; }

  /* search/filter */
  .filter-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.8rem; }
  .filter-input {
    flex: 1; min-width: 160px; padding: 0.4rem 0.8rem;
    background: rgba(0,0,0,0.2); border: 1px solid var(--border2);
    border-radius: 7px; color: var(--text); font-family: inherit; font-size: 0.82rem; outline: none;
  }
  .filter-input:focus { border-color: rgba(99,102,241,0.45); }
  .filter-input::placeholder { color: var(--muted); }

  /* refresh badge */
  .refresh-badge { font-size: 0.65rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; }

  /* section split */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  @media (max-width: 640px) {
    .match-score { font-size: 1.8rem; }
    .match-score-block { padding: 0 0.8rem; }
    .tab-btn span { display: none; }
  }

  /* scrollbar */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.3); border-radius: 3px; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-brand">
    <h1><i class="fas fa-chart-bar"></i> Galaxy Stats</h1>
  </div>
  <nav class="header-nav">
    <span class="refresh-badge" id="lastUpdate"><i class="fas fa-sync-alt"></i> —</span>
    <a href="/admin" class="btn btn-ghost"><i class="fas fa-shield-alt"></i> Admin</a>
  </nav>
</header>

<div class="container">

  <div class="tabs-bar">
    <button class="tab-btn active" data-tab="match"><i class="fas fa-fire"></i> <span>Current Match</span></button>
    <button class="tab-btn" data-tab="players"><i class="fas fa-trophy"></i> <span>Player Ratings</span></button>
    <button class="tab-btn" data-tab="teams"><i class="fas fa-users"></i> <span>Team Ratings</span></button>
    <button class="tab-btn" data-tab="history"><i class="fas fa-history"></i> <span>Match History</span></button>
    <button class="tab-btn" data-tab="h2h"><i class="fas fa-exchange-alt"></i> <span>Head 2 Head</span></button>
  </div>

  <!-- ═══════════════════════════════════════════════ TAB: MATCH ═══ -->
  <div class="tab-panel active" id="tab-match">
    <div id="match-no-data" class="no-data" style="display:none">
      <i class="fas fa-satellite-dish" style="font-size:2rem;margin-bottom:0.8rem;display:block;opacity:.3"></i>
      No active match. Waiting for GSI data...
    </div>
    <div id="match-content">
      <!-- scoreline -->
      <div class="match-header" id="match-scoreline">
        <div class="match-team ct" id="mc-ct">
          <img class="match-team-logo" id="mc-ct-logo" src="" alt="" style="display:none">
          <div class="match-team-name" id="mc-ct-name">CT</div>
          <div class="match-team-side">Counter-Terrorist</div>
        </div>
        <div class="match-score-block">
          <div class="match-score">
            <span id="mc-score-ct" class="ct-score" style="color:#38bdf8">0</span>
            <span class="sep">:</span>
            <span id="mc-score-t" style="color:#fbbf24">0</span>
          </div>
          <div class="match-map" id="mc-map">—</div>
          <div class="match-rounds" id="mc-rounds">0 rounds played</div>
        </div>
        <div class="match-team t" id="mc-t">
          <img class="match-team-logo" id="mc-t-logo" src="" alt="" style="display:none">
          <div class="match-team-name" id="mc-t-name">T</div>
          <div class="match-team-side">Terrorist</div>
        </div>
      </div>

      <!-- player tables -->
      <div class="two-col" style="margin-top:0.8rem">
        <div class="card">
          <div class="card-header">
            <div class="card-title" style="color:#38bdf8"><i class="fas fa-shield-alt"></i> CT Side</div>
            <span class="live-badge"><span class="live-dot"></span> LIVE</span>
          </div>
          <div class="card-body" style="padding:0">
            <table class="stats-table" id="tbl-ct">
              <thead><tr>
                <th>Player</th>
                <th class="r">K</th><th class="r">D</th><th class="r">A</th>
                <th class="r">ADR</th><th class="r">K/D</th><th class="r">KAST%</th>
                <th class="r">HS%</th><th class="r" title="GalaxyRating">Rating</th>
              </tr></thead>
              <tbody id="tbody-ct"></tbody>
            </table>
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <div class="card-title" style="color:#fbbf24"><i class="fas fa-bomb"></i> T Side</div>
            <span class="live-badge"><span class="live-dot"></span> LIVE</span>
          </div>
          <div class="card-body" style="padding:0">
            <table class="stats-table" id="tbl-t">
              <thead><tr>
                <th>Player</th>
                <th class="r">K</th><th class="r">D</th><th class="r">A</th>
                <th class="r">ADR</th><th class="r">K/D</th><th class="r">KAST%</th>
                <th class="r">HS%</th><th class="r" title="GalaxyRating">Rating</th>
              </tr></thead>
              <tbody id="tbody-t"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ TAB: PLAYERS ═══ -->
  <div class="tab-panel" id="tab-players">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-trophy"></i> Global Player Ratings</div>
        <div class="filter-bar" style="margin:0">
          <input class="filter-input" id="filter-players" placeholder="Search player..." style="min-width:180px">
        </div>
      </div>
      <div class="card-body" style="padding:0">
        <table class="stats-table" id="tbl-global-players">
          <thead><tr>
            <th>#</th>
            <th>Player</th>
            <th class="r" data-sort="matchesPlayed">M</th>
            <th class="r" data-sort="kills">K</th>
            <th class="r" data-sort="deaths">D</th>
            <th class="r" data-sort="assists">A</th>
            <th class="r" data-sort="adr">ADR</th>
            <th class="r" data-sort="kd">K/D</th>
            <th class="r" data-sort="kast">KAST%</th>
            <th class="r" data-sort="headshots">HS</th>
            <th class="r" data-sort="kpr">KPR</th>
            <th class="r" data-sort="galaxyRating">GalaxyRating</th>
          </tr></thead>
          <tbody id="tbody-global-players"></tbody>
        </table>
        <div class="no-data" id="no-global-players" style="display:none">No player stats yet. Play some matches!</div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ TAB: TEAMS ═══ -->
  <div class="tab-panel" id="tab-teams">
    <div class="card" style="margin-bottom:0.8rem">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-users"></i> Global Team Ratings</div>
      </div>
      <div class="card-body">
        <div class="teams-grid" id="teams-grid">
          <div class="no-data" style="grid-column:1/-1">No team stats yet.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ TAB: HISTORY ═══ -->
  <div class="tab-panel" id="tab-history">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-history"></i> Match History</div>
        <div class="filter-bar" style="margin:0">
          <input class="filter-input" id="filter-history" placeholder="Search map or team..." style="min-width:180px">
        </div>
      </div>
      <div class="card-body">
        <div class="history-list" id="history-list">
          <div class="no-data">No match history yet.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ TAB: H2H ═══ -->
  <div class="tab-panel" id="tab-h2h">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="fas fa-exchange-alt"></i> Head 2 Head</div>
      </div>
      <div class="card-body">
        <div class="h2h-search">
          <select class="h2h-select" id="h2h-team1"><option value="">— Select Team 1 —</option></select>
          <select class="h2h-select" id="h2h-team2"><option value="">— Select Team 2 —</option></select>
          <button class="btn btn-primary" id="h2h-go"><i class="fas fa-search"></i> Compare</button>
        </div>
        <div class="h2h-result" id="h2h-result"></div>
      </div>
    </div>
  </div>

</div>

<!-- ═══════ Match detail modal ═════════════════════════════════════════════ -->
<div class="modal-bg" id="modal-bg">
  <div class="modal-box">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">Match Details</div>
      <button class="modal-close" id="modal-close">&times;</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>
</div>

<script>
// ── Helpers ────────────────────────────────────────────────────────────────
function ratingColor(r) {
  if (r >= 1.15) return '#4ade80';
  if (r >= 1.0)  return '#a3e635';
  if (r >= 0.85) return '#fbbf24';
  return '#f87171';
}
function ratingBar(r, max) {
  const pct = Math.min(100, (r / (max || 2)) * 100);
  return `<div class="rating-bar-wrap">
    <div class="rating-bar"><div class="rating-bar-fill" style="width:${pct}%;background:${ratingColor(r)}"></div></div>
    <div class="rating-val" style="color:${ratingColor(r)}">${r.toFixed(2)}</div>
  </div>`;
}
function avatar(photo, name) {
  if (photo) return `<img class="player-avatar" src="${photo}" alt="${name}" onerror="this.style.display='none';this.nextSibling.style.display='flex'">
    <div class="player-avatar-ph" style="display:none"><i class="fas fa-user"></i></div>`;
  return `<div class="player-avatar-ph"><i class="fas fa-user"></i></div>`;
}
function teamLogo(logo, name) {
  if (logo) return `<img class="team-logo-sm" src="${logo}" alt="${name}" onerror="this.style.display='none'">`;
  return `<div class="team-logo-ph"><i class="fas fa-shield-alt"></i></div>`;
}
function fmt(n) { return n !== undefined && n !== null ? n : '—'; }
function hs(kills, headshots) {
  if (!kills) return '0%';
  return Math.round((headshots / kills) * 100) + '%';
}
function ago(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  const now = Date.now();
  const diff = now - d.getTime();
  if (diff < 60000) return 'just now';
  if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
  return d.toLocaleDateString();
}

// ── Tab switching ──────────────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// ── Modal ──────────────────────────────────────────────────────────────────
document.getElementById('modal-close').addEventListener('click', () => {
  document.getElementById('modal-bg').classList.remove('open');
});
document.getElementById('modal-bg').addEventListener('click', e => {
  if (e.target === document.getElementById('modal-bg'))
    document.getElementById('modal-bg').classList.remove('open');
});

// ── Table sort ─────────────────────────────────────────────────────────────
let sortState = { col: 'galaxyRating', dir: -1 };
function applySortHeaders(tableId, data, renderFn) {
  const thead = document.querySelector('#' + tableId + ' thead tr');
  if (!thead) return;
  thead.querySelectorAll('th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      if (sortState.col === col) sortState.dir *= -1;
      else { sortState.col = col; sortState.dir = -1; }
      thead.querySelectorAll('th').forEach(t => t.classList.remove('sort-asc','sort-desc'));
      th.classList.add(sortState.dir === 1 ? 'sort-asc' : 'sort-desc');
      data.sort((a,b) => (a[col]??0) < (b[col]??0) ? sortState.dir : -sortState.dir);
      renderFn(data);
    });
  });
}

// ─────────────────────────────────────────────────────────────────────────
// MATCH TAB
// ─────────────────────────────────────────────────────────────────────────
function playerMatchRow(p, allPlayers) {
  const hsStr = hs(p.kills, p.headshots);
  return `<tr>
    <td><div class="player-cell">${avatar(p.photo, p.name)}
      <div><div class="player-name-text">${p.name || p.steamId || '—'}</div></div>
    </div></td>
    <td class="r val-hi">${fmt(p.kills)}</td>
    <td class="r">${fmt(p.deaths)}</td>
    <td class="r">${fmt(p.assists)}</td>
    <td class="r">${fmt(p.adr)}</td>
    <td class="r ${p.kd >= 1 ? 'val-good' : 'val-bad'}">${fmt(p.kd)}</td>
    <td class="r">${fmt(p.kast)}%</td>
    <td class="r">${hsStr}</td>
    <td class="r">${ratingBar(p.galaxyRating, 2)}</td>
  </tr>`;
}

function renderMatchTab(data) {
  if (!data) {
    document.getElementById('match-no-data').style.display = '';
    document.getElementById('match-content').style.display = 'none';
    return;
  }
  document.getElementById('match-no-data').style.display = 'none';
  document.getElementById('match-content').style.display = '';

  document.getElementById('mc-ct-name').textContent = data.teamCT?.name || 'CT';
  document.getElementById('mc-t-name').textContent  = data.teamT?.name  || 'T';
  document.getElementById('mc-score-ct').textContent = data.teamCT?.score ?? 0;
  document.getElementById('mc-score-t').textContent  = data.teamT?.score  ?? 0;
  document.getElementById('mc-map').textContent = (data.mapName || '—').replace('de_','').toUpperCase();
  document.getElementById('mc-rounds').textContent = (data.roundCount || 0) + ' rounds played';

  const ctLogoEl = document.getElementById('mc-ct-logo');
  const tLogoEl  = document.getElementById('mc-t-logo');
  if (data.teamCT?.logo) { ctLogoEl.src = data.teamCT.logo; ctLogoEl.style.display = ''; }
  if (data.teamT?.logo)  { tLogoEl.src  = data.teamT.logo;  tLogoEl.style.display  = ''; }

  const players = Object.values(data.players || {});
  const ctPlayers = players.filter(p => {
    const raw = (data._raw || {})[p.steamId];
    return raw?.team === 'CT' || p._team === 'CT';
  });
  const tPlayers = players.filter(p => {
    const raw = (data._raw || {})[p.steamId];
    return raw?.team === 'T' || p._team === 'T';
  });

  // fallback: split by kills if teams not available
  const sorted = [...players].sort((a,b) => b.kills - a.kills);
  const half = Math.ceil(sorted.length / 2);
  const ctFinal = ctPlayers.length ? ctPlayers.sort((a,b)=>b.kills-a.kills) : sorted.slice(0, half);
  const tFinal  = tPlayers.length  ? tPlayers.sort((a,b)=>b.kills-a.kills)  : sorted.slice(half);

  document.getElementById('tbody-ct').innerHTML = ctFinal.map(p => playerMatchRow(p, players)).join('') || `<tr><td colspan="9" class="no-data">No data</td></tr>`;
  document.getElementById('tbody-t').innerHTML  = tFinal.map(p => playerMatchRow(p, players)).join('')  || `<tr><td colspan="9" class="no-data">No data</td></tr>`;
}

// ─────────────────────────────────────────────────────────────────────────
// PLAYERS TAB
// ─────────────────────────────────────────────────────────────────────────
let globalPlayersData = [];

function renderGlobalPlayersTable(data) {
  const tbody = document.getElementById('tbody-global-players');
  const noData = document.getElementById('no-global-players');
  if (!data.length) { tbody.innerHTML = ''; noData.style.display = ''; return; }
  noData.style.display = 'none';
  tbody.innerHTML = data.map((p, i) => {
    const rank = i === 0 ? `<span class="rank-1">1</span>`
               : i === 1 ? `<span class="rank-2">2</span>`
               : i === 2 ? `<span class="rank-3">3</span>`
               : i + 1;
    return `<tr>
      <td class="c">${rank}</td>
      <td><div class="player-cell">${avatar(p.photo, p.name)}
        <div>
          <div class="player-name-text">${p.name || p.steamId || '—'}</div>
          <div class="player-team-tag">${p.matchesPlayed} match${p.matchesPlayed !== 1 ? 'es' : ''}</div>
        </div>
      </div></td>
      <td class="r">${fmt(p.matchesPlayed)}</td>
      <td class="r">${fmt(p.kills)}</td>
      <td class="r">${fmt(p.deaths)}</td>
      <td class="r">${fmt(p.assists)}</td>
      <td class="r">${fmt(p.adr)}</td>
      <td class="r ${p.kd >= 1 ? 'val-good':'val-bad'}">${fmt(p.kd)}</td>
      <td class="r">${fmt(p.kast)}%</td>
      <td class="r">${fmt(p.headshots)}</td>
      <td class="r">${fmt(p.kpr)}</td>
      <td class="r">${ratingBar(p.galaxyRating, 2)}</td>
    </tr>`;
  }).join('');
}

document.getElementById('filter-players').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  const filtered = globalPlayersData.filter(p => (p.name||'').toLowerCase().includes(q) || p.steamId.includes(q));
  renderGlobalPlayersTable(filtered);
});

// ─────────────────────────────────────────────────────────────────────────
// TEAMS TAB
// ─────────────────────────────────────────────────────────────────────────
function renderTeamsGrid(data) {
  const grid = document.getElementById('teams-grid');
  if (!data.length) { grid.innerHTML = '<div class="no-data" style="grid-column:1/-1">No team stats yet.</div>'; return; }
  grid.innerHTML = data.map(t => `
    <div class="team-stat-card">
      <div class="team-stat-card-header">
        ${teamLogo(t.logo, t.name)}
        <div>
          <div class="team-stat-name">${t.name}</div>
          <div style="font-size:0.68rem;color:var(--muted)">${t.matchesPlayed} match${t.matchesPlayed !== 1 ? 'es' : ''}</div>
        </div>
        <div style="margin-left:auto;font-size:0.85rem;font-weight:800;color:${t.winRate>=50?'#4ade80':'#f87171'}">${t.winRate}%</div>
      </div>
      <div class="winrate-bar"><div class="winrate-fill" style="width:${t.winRate}%"></div></div>
      <div class="team-stat-row"><span class="team-stat-label">Wins / Losses</span><span class="team-stat-value">${t.matchesWon} / ${t.matchesPlayed - t.matchesWon}</span></div>
      <div class="team-stat-row"><span class="team-stat-label">Round W/L</span><span class="team-stat-value">${t.roundsWon} / ${t.roundsLost}</span></div>
      <div class="team-stat-row"><span class="team-stat-label">Round Win%</span><span class="team-stat-value" style="color:${t.roundWinRate>=50?'#4ade80':'#f87171'}">${t.roundWinRate}%</span></div>
    </div>
  `).join('');
}

// ─────────────────────────────────────────────────────────────────────────
// HISTORY TAB
// ─────────────────────────────────────────────────────────────────────────
let allHistory = [];

function renderHistory(data) {
  const list = document.getElementById('history-list');
  if (!data.length) { list.innerHTML = '<div class="no-data">No match history yet.</div>'; return; }
  list.innerHTML = data.map(m => `
    <div class="history-item" data-id="${m.id}">
      <div class="history-map-badge">${(m.mapName||'?').replace('de_','').toUpperCase()}</div>
      <div class="history-teams">
        ${teamLogo(m.teamCT?.logo, m.teamCT?.name)}
        <span>${m.teamCT?.name || 'CT'}</span>
        <span class="history-score"><span class="ct-score">${m.teamCT?.score??0}</span> : <span class="t-score">${m.teamT?.score??0}</span></span>
        <span>${m.teamT?.name || 'T'}</span>
        ${teamLogo(m.teamT?.logo, m.teamT?.name)}
      </div>
      ${m.winner ? `<span class="winner-tag">🏆 ${m.winner}</span>` : ''}
      <span class="rounds-tag">${m.roundCount||0}r</span>
      <span class="history-date">${ago(m.finishedAt || m.startedAt)}</span>
    </div>
  `).join('');
  list.querySelectorAll('.history-item').forEach(el => {
    el.addEventListener('click', () => openMatchDetail(el.dataset.id));
  });
}

document.getElementById('filter-history').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  renderHistory(allHistory.filter(m =>
    (m.mapName||'').toLowerCase().includes(q) ||
    (m.teamCT?.name||'').toLowerCase().includes(q) ||
    (m.teamT?.name||'').toLowerCase().includes(q)
  ));
});

function openMatchDetail(id) {
  const m = allHistory.find(x => x.id === id);
  if (!m) return;
  const players = Object.values(m.players || {}).sort((a,b) => b.galaxyRating - a.galaxyRating);
  document.getElementById('modal-title').textContent =
    `${(m.mapName||'').replace('de_','').toUpperCase()} — ${m.teamCT?.name||'CT'} ${m.teamCT?.score??0} : ${m.teamT?.score??0} ${m.teamT?.name||'T'}`;
  document.getElementById('modal-body').innerHTML = `
    <div style="margin-bottom:0.8rem;font-size:0.72rem;color:var(--muted)">
      <i class="fas fa-calendar"></i> ${new Date(m.startedAt||m.finishedAt).toLocaleString()}
      &nbsp;·&nbsp; ${m.roundCount||0} rounds
      ${m.winner ? `&nbsp;·&nbsp; <span style="color:#4ade80">Winner: ${m.winner}</span>` : ''}
    </div>
    <table class="stats-table">
      <thead><tr>
        <th>Player</th><th class="r">K</th><th class="r">D</th><th class="r">A</th>
        <th class="r">ADR</th><th class="r">K/D</th><th class="r">KAST%</th>
        <th class="r">HS%</th><th class="r">Rating</th>
      </tr></thead>
      <tbody>${players.map(p => `<tr>
        <td><div class="player-cell">${avatar(p.photo, p.name)}
          <div class="player-name-text">${p.name||p.steamId||'—'}</div>
        </div></td>
        <td class="r val-hi">${p.kills}</td><td class="r">${p.deaths}</td><td class="r">${p.assists}</td>
        <td class="r">${p.adr}</td>
        <td class="r ${p.kd>=1?'val-good':'val-bad'}">${p.kd}</td>
        <td class="r">${p.kast}%</td>
        <td class="r">${hs(p.kills, p.headshots)}</td>
        <td class="r">${ratingBar(p.galaxyRating, 2)}</td>
      </tr>`).join('')}</tbody>
    </table>
  `;
  document.getElementById('modal-bg').classList.add('open');
}

// ─────────────────────────────────────────────────────────────────────────
// H2H TAB
// ─────────────────────────────────────────────────────────────────────────
function populateH2HSelects(teamNames) {
  const s1 = document.getElementById('h2h-team1');
  const s2 = document.getElementById('h2h-team2');
  const opts = teamNames.map(n => `<option value="${n}">${n}</option>`).join('');
  s1.innerHTML = '<option value="">— Team 1 —</option>' + opts;
  s2.innerHTML = '<option value="">— Team 2 —</option>' + opts;
}

document.getElementById('h2h-go').addEventListener('click', () => {
  const t1 = document.getElementById('h2h-team1').value;
  const t2 = document.getElementById('h2h-team2').value;
  if (!t1 || !t2 || t1 === t2) {
    document.getElementById('h2h-result').innerHTML = '<div class="no-data">Select two different teams.</div>';
    return;
  }
  const matches = allHistory.filter(m => {
    const names = [(m.teamCT?.name||'').toLowerCase(), (m.teamT?.name||'').toLowerCase()];
    return names.includes(t1.toLowerCase()) && names.includes(t2.toLowerCase());
  });
  if (!matches.length) {
    document.getElementById('h2h-result').innerHTML = `<div class="no-data">No matches found between <b>${t1}</b> and <b>${t2}</b>.</div>`;
    return;
  }
  let w1 = 0, w2 = 0, draws = 0;
  matches.forEach(m => {
    if (!m.winner) draws++;
    else if (m.winner.toLowerCase() === t1.toLowerCase()) w1++;
    else if (m.winner.toLowerCase() === t2.toLowerCase()) w2++;
    else draws++;
  });
  document.getElementById('h2h-result').innerHTML = `
    <div class="h2h-scoreline">
      <div style="text-align:center">
        <div class="h2h-team-name">${t1}</div>
        <div class="h2h-label">Team 1</div>
      </div>
      <div style="text-align:center">
        <div class="h2h-scores"><span style="color:#4ade80">${w1}</span> <span style="color:var(--muted)">–</span> <span style="color:#f87171">${w2}</span></div>
        <div class="h2h-label">${matches.length} match${matches.length!==1?'es':''} · ${draws} draw${draws!==1?'s':''}</div>
      </div>
      <div style="text-align:center">
        <div class="h2h-team-name">${t2}</div>
        <div class="h2h-label">Team 2</div>
      </div>
    </div>
    <div class="history-list">${matches.map(m => `
      <div class="history-item" data-id="${m.id}">
        <div class="history-map-badge">${(m.mapName||'?').replace('de_','').toUpperCase()}</div>
        <div class="history-teams">
          <span>${m.teamCT?.name||'CT'}</span>
          <span class="history-score"><span class="ct-score">${m.teamCT?.score??0}</span> : <span class="t-score">${m.teamT?.score??0}</span></span>
          <span>${m.teamT?.name||'T'}</span>
        </div>
        ${m.winner?`<span class="winner-tag">🏆 ${m.winner}</span>`:''}
        <span class="history-date">${ago(m.finishedAt||m.startedAt)}</span>
      </div>
    `).join('')}</div>
  `;
  document.getElementById('h2h-result').querySelectorAll('.history-item').forEach(el => {
    el.addEventListener('click', () => openMatchDetail(el.dataset.id));
  });
});

// ─────────────────────────────────────────────────────────────────────────
// DATA FETCH
// ─────────────────────────────────────────────────────────────────────────
async function fetchAll() {
  try {
    const [matchRes, playersRes, teamsRes, histRes] = await Promise.all([
      fetch('/api/stats/match'),
      fetch('/api/stats/players'),
      fetch('/api/stats/teams'),
      fetch('/api/stats/history?limit=50'),
    ]);
    const [matchData, playersData, teamsData, histData] = await Promise.all([
      matchRes.json(), playersRes.json(), teamsRes.json(), histRes.json(),
    ]);

    // Match
    renderMatchTab(matchData.status === 'live' ? matchData.data : null);

    // Global players
    globalPlayersData = playersData || [];
    renderGlobalPlayersTable(globalPlayersData);
    applySortHeaders('tbl-global-players', globalPlayersData, renderGlobalPlayersTable);

    // Teams
    renderTeamsGrid(teamsData || []);

    // History
    allHistory = (histData.data || []);
    renderHistory(allHistory);
    const teamNames = [...new Set([
      ...allHistory.map(m => m.teamCT?.name).filter(Boolean),
      ...allHistory.map(m => m.teamT?.name).filter(Boolean),
    ])].sort();
    populateH2HSelects(teamNames);

    // Timestamp
    document.getElementById('lastUpdate').innerHTML =
      `<i class="fas fa-sync-alt"></i> ${new Date().toLocaleTimeString()}`;
  } catch (e) {
    console.error('Stats fetch error:', e);
  }
}

fetchAll();
// Auto-refresh match tab every 3s, everything else every 15s
setInterval(() => {
  fetch('/api/stats/match').then(r=>r.json()).then(d => {
    renderMatchTab(d.status === 'live' ? d.data : null);
    document.getElementById('lastUpdate').innerHTML =
      `<i class="fas fa-sync-alt"></i> ${new Date().toLocaleTimeString()}`;
  });
}, 3000);
setInterval(fetchAll, 15000);
</script>
</body>
</html>
